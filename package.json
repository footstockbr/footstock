{
  "name": "foot-stock",
  "version": "1.0.0",
  "private": true,
  "description": "O mercado de ações do futebol brasileiro",
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "npm@10.2.3",
  "prisma": {
    "seed": "ts-node --project tsconfig.seed.json -r tsconfig-paths/register prisma/seed/index-local.ts"
  },
  "scripts": {
    "validate": "npm run lint && npm run typecheck",
    "prebuild": "npm run validate",
    "setup": "./scripts/bootstrap.sh",
    "reset": "./scripts/bootstrap.sh --reset",
    "health": "./scripts/bootstrap.sh --health",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:mutation": "stryker run",
    "test:mutation:incremental": "stryker run --incremental",
    "test:mutation:quick": "stryker run --mutate 'lib/services/OrderService.ts'",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:seed": "prisma db seed",
    "db:seed:reset": "prisma migrate reset --force",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:reset": "docker compose -f docker-compose.dev.yml down -v && docker compose -f docker-compose.dev.yml up -d",
    "staging:validate": "bash scripts/staging-validate.sh",
    "test:integration": "jest --config jest.integration.config.ts --runInBand",
    "test:integration:watch": "jest --config jest.integration.config.ts --watch",
    "test:all": "jest && npm run test:integration",
    "test:integration:setup": "docker compose -f docker-compose.test.yml up -d && sleep 3 && TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/foot_stock_test npx prisma migrate deploy",
    "test:contracts": "jest --config tests/contracts/jest.contract.config.ts",
    "test:a11y": "playwright test tests/a11y",
    "test:load:smoke": "k6 run --env SCENARIO=smoke tests/load/run-all.js",
    "test:load": "k6 run tests/load/run-all.js",
    "test:load:stress": "k6 run --env SCENARIO=stress tests/load/run-all.js",
    "analyze": "ANALYZE=true next build",
    "docker:up": "docker compose up",
    "docker:up:build": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:clean": "docker compose down -v",
    "docker:motor:build": "docker build -t foot-stock-motor:latest ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@hookform/resolvers": "^3.0.0",
    "@prisma/adapter-pg": "7.6.0",
    "@prisma/client": "^7.6.0",
    "@sentry/nextjs": "^10.47.0",
    "@simplewebauthn/browser": "^9.0.1",
    "@simplewebauthn/server": "^9.0.3",
    "@simplewebauthn/types": "^9.0.1",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.0.0",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/bcryptjs": "2.4.6",
    "axios": "^1.0.0",
    "bcryptjs": "3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "expo": "^55.0.9",
    "ioredis": "^5.3.0",
    "jszip": "^3.10.1",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^1.7.0",
    "next": "^15.0.0",
    "pg": "8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.0.0",
    "recharts": "^3.8.1",
    "resend": "^6.9.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@next/bundle-analyzer": "^16.2.1",
    "@playwright/test": "^1.48.0",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/jest-runner": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "postcss": "^8.0.0",
    "prettier": "^3.0.0",
    "prisma": "^7.6.0",
    "tailwindcss": "^4.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
