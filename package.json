{
  "name": "foot-stock",
  "version": "1.0.0",
  "private": true,
  "description": "O mercado de ações do futebol brasileiro",
  "prisma": {
    "seed": "ts-node --project tsconfig.seed.json -r tsconfig-paths/register prisma/seed/index.ts"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:reset": "docker compose -f docker-compose.dev.yml down -v && docker compose -f docker-compose.dev.yml up -d",
    "staging:validate": "bash scripts/staging-validate.sh",
    "test:a11y": "playwright test tests/a11y",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.0.0",
    "@prisma/client": "^6.0.0",
    "@sentry/nextjs": "^8.0.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.0.0",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-virtual": "^3.13.23",
    "@upstash/ratelimit": "^2.0.0",
    "@upstash/redis": "^1.0.0",
    "axios": "^1.0.0",
    "clsx": "^2.1.1",
    "ioredis": "^5.3.0",
    "lucide-react": "^1.7.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.0.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@next/bundle-analyzer": "^16.2.1",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "postcss": "^8.0.0",
    "prettier": "^3.0.0",
    "prisma": "^6.0.0",
    "tailwindcss": "^4.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
