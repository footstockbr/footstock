# NPM Configuration — FootStock
# Enforce Node/npm versions, exact dependencies, security audits

# Enforce exact versions declared in package.json
save-exact=true

# Enforce Node version from engines field
engine-strict=true

# Audit level: moderate (fails on moderate+ vulnerabilities)
audit-level=moderate

# Reduce npm output noise
loglevel=warn

# Default registry (no hardcoded tokens here)
registry=https://registry.npmjs.org/

# Always use lockfile (avoid package-lock.json drift)
legacy-peer-deps=false

# Enable strict SSL for security
strict-ssl=true
