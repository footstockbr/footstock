# =====================================================
# FOOT STOCK — Template de Variáveis de Ambiente
# =====================================================
# Copie para .env e preencha com valores reais
# Para environments adicionais, veja: .env.staging, .env.production
# =====================================================

# --- AMBIENTE ---
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_VERSION="1.0.0"
NEXT_PUBLIC_SITE_URL="https://foot-stock.app"

# --- DATABASE (Supabase PostgreSQL ou Local Docker) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/foot_stock_dev?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/foot_stock_dev?schema=public"

# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# --- REDIS ---
REDIS_URL="redis://default:[password]@[host]:[port]"

# --- AUTH & SECURITY (Auto-gerados com /env-creation) ---
JWT_SECRET="[min-32-caracteres-aleatorios]"
NEXTAUTH_SECRET="[gere-com-openssl-rand-base64-32]"
CRON_SECRET="[gere-com-openssl-rand-base64-32]"
REVALIDATE_SECRET="[gere-com-openssl-rand-base64-32]"
CSRF_SECRET="[gere-com-openssl-rand-base64-32]"
METRICS_API_SECRET="[gere-com-openssl-rand-base64-32]"
ENCRYPTION_KEY="[gere-com-openssl-rand-hex-32]"
INTERNAL_JOBS_SECRET="[gere-com-openssl-rand-hex-32]"
API_KEY_INTERNAL="[gere-com-uuidgen]"
CPF_HASH_SALT="[salt-aleatorio-secreto-min-32-chars]"

# --- WEBAUTHN (Passwordless) ---
WEBAUTHN_RP_ID="localhost"
WEBAUTHN_RP_NAME="Foot Stock"

# --- MOTOR (Serviço Externo) ---
MOTOR_SECRET_TOKEN="[token-para-autenticar-requests-inter-servico]"

# --- LIGAS ---
INVITE_TOKEN_SECRET="[token-aleatorio-min-32-chars]"
NEXT_PUBLIC_ENABLE_EMBLEM_UPLOAD="false"

# --- PUSH NOTIFICATIONS (Web Push VAPID) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY="[gere-com-npx-web-push-generate-vapid-keys]"
VAPID_PRIVATE_KEY="[gere-com-npx-web-push-generate-vapid-keys]"

# --- EMAIL (Resend) ---
# Como obter: https://resend.com/api-keys
RESEND_API_KEY="re_[chave-resend]"
RESEND_FROM_EMAIL="noreply@footstock.app"

# --- VERIFICACAO DE MAIORIDADE (FlagCheck) ---
# Como obter: https://www.flagcheck.com.br
FLAGCHECK_API_URL="https://api.flagcheck.com.br/v1"
FLAGCHECK_API_KEY="[api-key]"

# --- SENTRY (Monitoramento de Erros) ---
# Como obter: https://sentry.io
NEXT_PUBLIC_SENTRY_DSN="https://[key]@o[org].ingest.sentry.io/[project]"
SENTRY_DSN="https://[key]@o[org].ingest.sentry.io/[project]"
SENTRY_ORG="[org-slug]"
SENTRY_PROJECT="foot-stock"
SENTRY_AUTH_TOKEN="[token-para-source-maps]"
# Extrair do seu DSN: https://[key]@o[ORG-ID].ingest.sentry.io/[project]
# Use: https://o[ORG-ID].ingest.sentry.io
SENTRY_INGEST_HOST="https://o[ORG-ID].ingest.sentry.io"

# --- IA (Anthropic Claude) ---
# Como obter: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-[chave-anthropic]"

# --- PAGAMENTOS ---
ACTIVE_GATEWAY="MERCADO_PAGO"

# Mercado Pago
MP_ACCESS_TOKEN="APP_USR-[access-token]"
NEXT_PUBLIC_MP_PUBLIC_KEY="APP_USR-[public-key]"
MP_WEBHOOK_SECRET="[webhook-secret]"

# PagSeguro
PAGSEGURO_EMAIL="[seu-email-pagseguro]"
PAGSEGURO_TOKEN="[pagseguro-account-token]"
PAGSEGURO_WEBHOOK_SECRET="[webhook-secret]"
PAGSEGURO_SANDBOX="true"

# PayPal
PAYPAL_CLIENT_ID="[paypal-client-id]"
PAYPAL_CLIENT_SECRET="[paypal-client-secret]"
PAYPAL_WEBHOOK_ID="[paypal-webhook-id]"
PAYPAL_SANDBOX="true"

# --- TESTING ---
E2E_SESSION_TOKEN="[token-para-e2e-tests]"
BASE_URL="http://localhost:3000"
TEST_ENV="development"
TEST_CRAQUE_EMAIL="craque@footstock.test"
TEST_CRAQUE_PASSWORD="TestCraque123!"
TEST_JOGADOR_EMAIL="jogador@footstock.test"
TEST_JOGADOR_PASSWORD="TestJogador123!"

# --- OBSERVABILIDADE ---
NSM_ALERT_THRESHOLD=200
NSM_TARGET=500
HEALTH_CHECK_DB_TIMEOUT_MS=3000
HEALTH_CHECK_REDIS_TIMEOUT_MS=2000
HEALTH_CHECK_MOTOR_TIMEOUT_MS=3000
HEALTH_CHECK_P95_MS=500

# --- UPTIME MONITOR ---
NEXT_PUBLIC_UPTIME_MONITOR_URL="[status-page-url]"

# --- MOTOR (Railway) ---
# URL do serviço motor no Railway (usado em vercel.json rewrites e lib/env.ts)
RAILWAY_URL="https://[projeto].up.railway.app"

# --- CORS ---
# Origins permitidas para requests CORS (separadas por vírgula se múltiplas)
ALLOWED_ORIGINS="https://footstock.com.br"
