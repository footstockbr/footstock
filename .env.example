# =====================================================
# FOOT STOCK — Template de Variáveis de Ambiente
# Copie para .env.local e preencha com valores reais
# =====================================================

# --- APP ---
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# --- DATABASE (Supabase PostgreSQL) ---
DATABASE_URL="postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:5432/postgres"

# --- DESENVOLVIMENTO LOCAL (docker-compose.dev.yml) ---
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/foot_stock_dev?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/foot_stock_dev"
# REDIS_URL="redis://localhost:6379"

# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# --- REDIS ---
REDIS_URL="redis://default:[password]@[host]:6379"
REDIS_REST_URL="https://[upstash-url]"
REDIS_REST_TOKEN="[upstash-token]"

# --- AUTH ---
JWT_SECRET="[min-32-caracteres-aleatorios]"
WEBAUTHN_RP_ID="foot-stock.app"
WEBAUTHN_RP_NAME="Foot Stock"
WEBAUTHN_ORIGIN="https://foot-stock.app"

# --- MOTOR RAILWAY ---
RAILWAY_URL="https://[motor-service].up.railway.app"
MOTOR_SECRET_TOKEN="[token-para-autenticar-requests-inter-servico]"
MOTOR_PORT=3001

# --- FLAGCHECK (Verificação de idade) ---
FLAGCHECK_API_URL="https://api.flagcheck.com.br/v1"
FLAGCHECK_API_KEY="[api-key]"

# --- SENTRY ---
NEXT_PUBLIC_SENTRY_DSN="https://[key]@o[org].ingest.sentry.io/[project]"
SENTRY_DSN="https://[key]@o[org].ingest.sentry.io/[project]"
SENTRY_ORG="[org-slug]"
SENTRY_PROJECT="foot-stock"
SENTRY_AUTH_TOKEN="[token-para-source-maps]"

# --- CPF HASH ---
CPF_HASH_SALT="[salt-aleatorio-secreto-min-32-chars]"
