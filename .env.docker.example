# =====================================================
# FOOT STOCK — Template para Docker Compose (dev local)
# =====================================================
# Arquivo de exemplo — PODE ser versionado (sem valores reais)
# Para criar o arquivo real: cp .env.docker.example .env.docker
#
# DIFERENÇA do .env/.env.local:
#   - DATABASE_URL aponta para "postgres" (serviço Docker), não localhost
#   - REDIS_URL aponta para "redis" (serviço Docker), não localhost
#   - MOTOR_* aponta para "motor" (serviço Docker), não localhost
# =====================================================

# --- AMBIENTE ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- DATABASE (PostgreSQL via Docker — serviço "postgres") ---
DATABASE_URL=postgresql://postgres:[POSTGRES_PASSWORD]@postgres:5432/footstock_dev?schema=public
DIRECT_URL=postgresql://postgres:[POSTGRES_PASSWORD]@postgres:5432/footstock_dev?schema=public

# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[anon-key]
SUPABASE_SERVICE_ROLE_KEY=[service-role-key]

# --- REDIS (serviço "redis") ---
REDIS_URL=redis://redis:6379

# --- AUTH & SECURITY ---
JWT_SECRET=[min-32-chars]
NEXTAUTH_SECRET=[gere-com: openssl rand -base64 32]
CRON_SECRET=[gere-com: openssl rand -base64 32]
REVALIDATE_SECRET=[gere-com: openssl rand -base64 32]
CSRF_SECRET=[gere-com: openssl rand -base64 32]
METRICS_API_SECRET=[gere-com: openssl rand -base64 32]
ENCRYPTION_KEY=[gere-com: openssl rand -hex 32]
INTERNAL_JOBS_SECRET=[gere-com: openssl rand -hex 32]
API_KEY_INTERNAL=[gere-com: uuidgen]
CPF_HASH_SALT=[salt-aleatorio-min-32-chars]

# --- WEBAUTHN ---
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Foot Stock

# --- MOTOR (serviço "motor" na porta 3001) ---
MOTOR_SECRET_TOKEN=[token-para-autenticar-requests-inter-servico]
MOTOR_TICK_INTERVAL_MS=10000

# --- LIGAS ---
INVITE_TOKEN_SECRET=[token-aleatorio-min-32-chars]
NEXT_PUBLIC_ENABLE_EMBLEM_UPLOAD=false

# --- PUSH NOTIFICATIONS (VAPID) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=[gere-com: npx web-push generate-vapid-keys]
VAPID_PRIVATE_KEY=[gere-com: npx web-push generate-vapid-keys]

# --- EMAIL ---
RESEND_API_KEY=re_[chave-resend]
RESEND_FROM_EMAIL=noreply@footstock.app

# --- VERIFICACAO DE MAIORIDADE ---
FLAGCHECK_API_URL=https://api.flagcheck.com.br/v1
FLAGCHECK_API_KEY=[api-key]

# --- SENTRY (desabilitar em dev — deixar em branco) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=foot-stock
SENTRY_AUTH_TOKEN=

# --- IA ---
ANTHROPIC_API_KEY=sk-ant-[chave-anthropic]

# --- PAGAMENTOS ---
ACTIVE_GATEWAY=MERCADO_PAGO
MP_ACCESS_TOKEN=TEST-[access-token]
NEXT_PUBLIC_MP_PUBLIC_KEY=TEST-[public-key]
MP_WEBHOOK_SECRET=[webhook-secret]
PAGSEGURO_EMAIL=[seu-email-pagseguro]
PAGSEGURO_TOKEN=[pagseguro-account-token]
PAGSEGURO_WEBHOOK_SECRET=[webhook-secret]
PAGSEGURO_SANDBOX=true
PAYPAL_CLIENT_ID=[paypal-client-id]
PAYPAL_CLIENT_SECRET=[paypal-client-secret]
PAYPAL_WEBHOOK_ID=[paypal-webhook-id]
PAYPAL_SANDBOX=true

# --- TESTING ---
E2E_SESSION_TOKEN=[token-para-e2e-tests]
BASE_URL=http://localhost:3000
TEST_ENV=development
TEST_CRAQUE_EMAIL=craque@footstock.test
TEST_CRAQUE_PASSWORD=TestCraque123!
TEST_JOGADOR_EMAIL=jogador@footstock.test
TEST_JOGADOR_PASSWORD=TestJogador123!

# --- OBSERVABILIDADE ---
NSM_ALERT_THRESHOLD=200
NSM_TARGET=500
HEALTH_CHECK_DB_TIMEOUT_MS=3000
HEALTH_CHECK_REDIS_TIMEOUT_MS=2000
HEALTH_CHECK_MOTOR_TIMEOUT_MS=3000
HEALTH_CHECK_P95_MS=500
NEXT_PUBLIC_UPTIME_MONITOR_URL=
