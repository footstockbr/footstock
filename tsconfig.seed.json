{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "outDir": ".seed-out",
    "paths": {
      "@/lib/*": ["./_lib_legacy_backup/*"],
      "@/*": ["./*"]
    }
  },
  "include": ["prisma/seed/**/*.ts", "_lib_legacy_backup/**/*.ts"]
}
