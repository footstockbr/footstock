generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────

enum PlanType {
  JOGADOR
  CRAQUE
  LENDA
}

enum OrderType {
  MARKET
  LIMIT
  STOP_LOSS
  TAKE_PROFIT
}

enum OrderSide {
  BUY
  SELL
}

enum OrderStatus {
  OPEN
  FILLED
  CANCELLED
  EXPIRED
  PARTIAL
}

enum AdminRole {
  SUPER_ADMIN
  ADMINISTRADOR
  MONITOR
  EDITOR
  MODERADOR
}

enum InvestorProfile {
  CONSERVADOR
  MODERADO
  ARROJADO
  ESPECULADOR
}

enum LeagueType {
  PUBLIC
  PRIVATE
  SPONSORED
}

enum NotificationType {
  // Alinhado com NOTIFICATION-SPEC.md (16 tipos)
  ORDER_EXECUTED
  ORDER_CANCELLED
  MARGIN_CALL_ALERT
  CIRCUIT_BREAKER
  NEWS_FAVORITE_CLUB
  PAYMENT_CONFIRMED
  PAYMENT_FAILED
  PLAN_CANCEL_ALERT
  DIVIDEND_CREDITED
  BONUS_CREDITED
  LEAGUE_RESULT
  ADMIN_BROADCAST
  // Afiliados e trava de cancelamento (NOTIFICATION-SPEC v2)
  AFFILIATE_COMMISSION_EARNED
  AFFILIATE_INVITE_JOINED
  CANCELLATION_LOCK_ACTIVE
  CANCELLATION_LOCK_LIQUIDATED
}

enum ImpactCategory {
  POSITIVE
  NEGATIVE
  NEUTRAL
}

enum Sentiment {
  BULLISH
  BEARISH
  NEUTRAL
}

enum Division {
  SERIE_A
  SERIE_B
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
}

enum SessionType {
  PRE_MARKET
  REGULAR
  AFTER_MARKET
  CLOSED
}

enum ConsentPurpose {
  TERMS
  MARKETING
  ANALYTICS
  THIRD_PARTY
}

// ─── Models ───────────────────────────────────────────────────────

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String
  phone           String?
  cpfHash         String           @unique @map("cpf_hash")
  birthDate       DateTime?        @db.Date @map("birth_date")
  planType        PlanType         @default(JOGADOR) @map("plan_type")
  adminRole       AdminRole?       @map("admin_role")
  investorProfile InvestorProfile? @map("investor_profile")
  tourCompleted   Boolean          @default(false) @map("tour_completed")
  favoriteClub    String?          @map("favorite_club")
  fsBalance       Decimal          @default(10000) @db.Decimal(18, 2) @map("fs_balance")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  orders            Order[]
  positions         Position[]
  transactions      Transaction[]
  subscriptions     Subscription[]
  payments          Payment[]
  notifications     Notification[]
  consents          Consent[]
  leagueMemberships LeagueMember[]
  forumPosts        ForumPost[]
  dataAccessLogs    DataAccessLog[]
  ownedLeagues      League[]            @relation("LeagueOwner")
  adminActions      AdminMarketAction[] @relation("AdminActor")

  @@map("users")
}

model Asset {
  id             String   @id @default(cuid())
  ticker         String   @unique
  name           String
  clubSlug       String   @unique @map("club_slug")
  division       Division
  cluster        String   // A_TOP | A_MID | A_SMALL | B_LIQUID | B_ILLIQ
  currentPrice   Decimal  @db.Decimal(18, 8) @map("current_price")
  openPrice      Decimal  @db.Decimal(18, 8) @map("open_price")
  closePrice     Decimal  @db.Decimal(18, 8) @map("close_price")
  volume         BigInt   @default(0)
  marketCap      Decimal  @db.Decimal(18, 2) @map("market_cap")
  isActive       Boolean  @default(true) @map("is_active")
  colorPrimary   String   @map("color_primary")
  colorSecondary String   @map("color_secondary")
  logoUrl        String?  @map("logo_url")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  priceHistory PriceHistory[]
  orders       Order[]
  positions    Position[]
  transactions Transaction[]
  sponsor      Sponsor?
  adminActions AdminMarketAction[]

  @@map("assets")
}

model Order {
  id            String      @id @default(cuid())
  userId        String      @map("user_id")
  assetId       String      @map("asset_id")
  type          OrderType
  side          OrderSide
  status        OrderStatus @default(OPEN)
  quantity      Int
  price         Decimal?    @db.Decimal(18, 8)
  executedPrice Decimal?    @db.Decimal(18, 8) @map("executed_price")
  fee           Decimal     @default(0) @db.Decimal(18, 8)
  expiresAt     DateTime?   @map("expires_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id])
  asset        Asset         @relation(fields: [assetId], references: [id])
  transactions Transaction[]

  @@index([userId])
  @@index([assetId])
  @@index([status])
  @@index([userId, status])
  @@map("orders")
}

model Position {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  assetId       String   @map("asset_id")
  quantity      Int
  avgPrice      Decimal  @db.Decimal(18, 8) @map("avg_price")
  totalInvested Decimal  @db.Decimal(18, 2) @map("total_invested")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id])
  asset Asset @relation(fields: [assetId], references: [id])

  @@unique([userId, assetId])
  @@index([userId])
  @@map("positions")
}

model Transaction {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  assetId     String    @map("asset_id")
  orderId     String?   @map("order_id")
  type        OrderType
  side        OrderSide
  quantity    Int
  price       Decimal   @db.Decimal(18, 8)
  fee         Decimal   @db.Decimal(18, 8)
  totalAmount Decimal   @db.Decimal(18, 2) @map("total_amount")
  createdAt   DateTime  @default(now()) @map("created_at")

  user  User   @relation(fields: [userId], references: [id])
  asset Asset  @relation(fields: [assetId], references: [id])
  order Order? @relation(fields: [orderId], references: [id])

  @@index([userId])
  @@index([assetId])
  @@index([userId, createdAt])
  @@map("transactions")
}

model PriceHistory {
  id          String      @id @default(cuid())
  assetId     String      @map("asset_id")
  timestamp   DateTime
  open        Decimal     @db.Decimal(18, 8)
  high        Decimal     @db.Decimal(18, 8)
  low         Decimal     @db.Decimal(18, 8)
  close       Decimal     @db.Decimal(18, 8)
  volume      BigInt      @default(0)
  sessionType SessionType @map("session_type")

  asset Asset @relation(fields: [assetId], references: [id])

  @@index([assetId])
  @@index([assetId, timestamp])
  @@map("price_history")
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String             @map("user_id")
  planType           PlanType           @map("plan_type")
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime           @map("current_period_start")
  currentPeriodEnd   DateTime           @map("current_period_end")
  cancelAtPeriodEnd  Boolean            @default(false) @map("cancel_at_period_end")
  gatewayId          String?            @map("gateway_id")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id])
  payments Payment[]

  @@index([userId])
  @@map("subscriptions")
}

model Payment {
  id              String        @id @default(cuid())
  userId          String        @map("user_id")
  subscriptionId  String        @map("subscription_id")
  amount          Decimal       @db.Decimal(18, 2)
  currency        String        @default("BRL")
  status          PaymentStatus @default(PENDING)
  gatewayId       String?       @map("gateway_id")
  gatewayResponse Json?         @map("gateway_response")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id])
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([userId])
  @@map("payments")
}

model News {
  id          String         @id @default(cuid())
  title       String
  content     String         @db.Text
  impact      ImpactCategory
  sentiment   Sentiment
  // Array de IDs de ativos relacionados (suporte nativo PostgreSQL)
  assetIds    String[]       @map("asset_ids")
  source      String?
  isPublished Boolean        @default(false) @map("is_published")
  publishedAt DateTime?      @map("published_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@index([publishedAt])
  @@index([isPublished])
  @@map("news")
}

model League {
  id         String     @id @default(cuid())
  name       String
  ownerId    String     @map("owner_id")
  type       LeagueType
  season     Int
  maxMembers Int        @default(20) @map("max_members")
  prizePool  Decimal    @default(0) @db.Decimal(18, 2) @map("prize_pool")
  isActive   Boolean    @default(true) @map("is_active")
  inviteCode String?    @unique @map("invite_code")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  owner      User           @relation("LeagueOwner", fields: [ownerId], references: [id])
  members    LeagueMember[]
  forumPosts ForumPost[]

  @@index([ownerId])
  @@map("leagues")
}

model LeagueMember {
  id       String   @id @default(cuid())
  leagueId String   @map("league_id")
  userId   String   @map("user_id")
  joinedAt DateTime @default(now()) @map("joined_at")
  score    Decimal  @default(0) @db.Decimal(18, 2)
  rank     Int      @default(0)

  league League @relation(fields: [leagueId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([leagueId, userId])
  @@index([leagueId])
  @@index([userId])
  @@map("league_members")
}

model ForumPost {
  id        String   @id @default(cuid())
  leagueId  String   @map("league_id")
  userId    String   @map("user_id")
  content   String   @db.Text
  isPinned  Boolean  @default(false) @map("is_pinned")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  league League @relation(fields: [leagueId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([leagueId])
  @@index([userId])
  @@map("forum_posts")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, isRead])
  @@map("notifications")
}

model Consent {
  id        String         @id @default(cuid())
  userId    String         @map("user_id")
  purpose   ConsentPurpose
  granted   Boolean
  grantedAt DateTime       @map("granted_at")
  revokedAt DateTime?      @map("revoked_at")
  createdAt DateTime       @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, purpose])
  @@index([userId])
  @@map("consents")
}

model DataAccessLog {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  action       String
  resourceType String   @map("resource_type")
  resourceId   String?  @map("resource_id")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("data_access_logs")
}

model Sponsor {
  id               String   @id @default(cuid())
  assetId          String   @unique @map("asset_id")
  name             String
  logoUrl          String?  @map("logo_url")
  contractStart    DateTime @map("contract_start")
  contractEnd      DateTime @map("contract_end")
  sponsorshipValue Decimal  @db.Decimal(18, 2) @map("sponsorship_value")
  createdAt        DateTime @default(now()) @map("created_at")

  asset Asset @relation(fields: [assetId], references: [id])

  @@map("sponsors")
}

model AdminMarketAction {
  id            String   @id @default(cuid())
  adminId       String   @map("admin_id")
  assetId       String   @map("asset_id")
  action        String   // INJECT_NEWS | PAUSE_ASSET | ADJUST_PRICE | HALT_TRADING
  reason        String   @db.Text
  previousPrice Decimal? @db.Decimal(18, 8) @map("previous_price")
  newPrice      Decimal? @db.Decimal(18, 8) @map("new_price")
  createdAt     DateTime @default(now()) @map("created_at")

  admin User  @relation("AdminActor", fields: [adminId], references: [id])
  asset Asset @relation(fields: [assetId], references: [id])

  @@index([adminId])
  @@index([assetId])
  @@index([createdAt])
  @@map("admin_market_actions")
}
