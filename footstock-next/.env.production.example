# =====================================================================
# FootStock — Variáveis de Ambiente de Produção
# =====================================================================
# INSTRUÇÕES:
#   1. Copie este arquivo para .env.production.local (nunca commitar!)
#   2. Preencha TODOS os valores obrigatórios antes do deploy
#   3. Nunca compartilhe este arquivo ou seus valores
#   Gerado por: module-30-finalizacao / TASK-0 ST003 em 2026-04-01
# =====================================================================

# ─── Supabase (Produção — usar projeto DIFERENTE do staging) ─────────
DATABASE_URL=           # postgres://USER:PASS@postgres.railway.internal:5432/railway (Railway internal)
NEXT_PUBLIC_SUPABASE_URL=           # https://[legacy-project].example.com (LEGADO — ver RUNBOOK-016)
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # chave anon pública — OK expor ao cliente
SUPABASE_SERVICE_ROLE_KEY=          # OBRIGATÓRIO: manter ONLY server-side, NUNCA NEXT_PUBLIC_

# ─── Redis Cloud (Produção) ───────────────────────────────────────────
REDIS_URL=                          # redis://default:PASS@redis.railway.internal:6379 (Railway internal)

# ─── IA — provider de LLM (Assessor IA + sentimento de notícias) ─────
AI_PROVIDER=kimi                    # kimi (default) | anthropic — ver src/lib/services/ai-provider.ts
ANTHROPIC_API_KEY=                  # sk-ant-... chave de produção (usada quando AI_PROVIDER=anthropic)
KIMI_API_KEY=                       # sk-kimi-... chave do Kimi (usada quando AI_PROVIDER=kimi)
KIMI_BASE_URL=https://api.kimi.com/coding  # endpoint Anthropic-compatível do Kimi for coding
KIMI_MODEL=kimi-for-coding          # modelo Kimi (override opcional)

# ─── Pagamentos — Produção (NÃO sandbox) ─────────────────────────────
# Nomes canônicos (Item 009): MERCADO_PAGO_* e PAGSEGURO_*. Os prefixos legados
# (MERCADO+PAGO sem underscore, e PAGO+SEGURO transposto) foram removidos — o gate
# e os testes de higiene falham se qualquer um deles reaparecer.

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=          # APP_USR-... token de transação/API de produção (cria cobranças)
MERCADO_PAGO_WEBHOOK_SECRET=        # secret de assinatura do webhook (x-signature)

# PagSeguro / PagBank
# Dois insumos DISTINTOS: (1) habilitação do gateway, (2) autenticidade do webhook.
PAGSEGURO_TOKEN=                    # (1) token de transação/API de produção (cria cobranças)
PAGSEGURO_NOTIFICATION_TOKEN=       # (2) token de autenticidade do webhook /orders (x-authenticity-token, Item 008)
PAGSEGURO_LEGACY_HMAC_FALLBACK=false # mantém o HMAC legado (x-pagseguro-signature) DESLIGADO; canônico = x-authenticity-token
PAGSEGURO_SANDBOX=false             # false em produção (gate marca SANDBOX_IN_PROD se sandbox em prod)
# NÃO use PAGSEGURO_WEBHOOK_SECRET como prova de autenticidade: é apenas o secret
# do HMAC legado, válido só com PAGSEGURO_LEGACY_HMAC_FALLBACK=true (migração).

# PayPal
PAYPAL_CLIENT_ID=                   # Client ID de produção (não sandbox)
PAYPAL_CLIENT_SECRET=               # Client Secret de produção (não sandbox)
PAYPAL_WEBHOOK_ID=                  # Webhook ID de produção (readiness de autenticidade)

# ─── Sentry (Monitoramento de erros em produção) ─────────────────────
SENTRY_DSN=                         # https://[key]@[org].ingest.sentry.io/[project]
NEXT_PUBLIC_SENTRY_DSN=             # mesmo valor — exposto ao browser para capturar erros FE
SENTRY_AUTH_TOKEN=                  # token para source maps (somente CI/CD)
SENTRY_ORG=                         # slug da organização no Sentry
SENTRY_PROJECT=                     # slug do projeto no Sentry (ex: foot-stock)

# ─── App URL ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=                # https://footstock.com.br (URL de produção sem trailing slash)
NEXT_PUBLIC_SITE_URL=               # https://footstock.com.br (mesmo valor)

# ─── WebAuthn (Biometria) ─────────────────────────────────────────────
WEBAUTHN_RP_ID=                     # footstock.com.br (domínio sem https://)
WEBAUTHN_RP_NAME=                   # FootStock
WEBAUTHN_ORIGIN=                    # https://footstock.com.br

# ─── Segurança — CPF Hash ─────────────────────────────────────────────
HMAC_CPF_SECRET=                    # RECOMENDADO: secret HMAC-SHA256 ≥32 chars, NUNCA mudar em produção
CPF_HASH_SALT=                      # LEGADO: fallback SHA-256+salt (usado se HMAC_CPF_SECRET ausente)

# ─── Cron e Tokens Internos ───────────────────────────────────────────
CRON_SECRET=                        # OBRIGATÓRIO: Bearer secret para /api/cron/* (min 32 chars)
INVITE_TOKEN_SECRET=                # OBRIGATÓRIO: JWT secret para tokens de convite de liga (min 32 chars)

# ─── Motor de Mercado (Railway) ───────────────────────────────────────
NEXT_PUBLIC_SOCKET_URL=             # https://[app].railway.app (URL do motor Node.js)

# ─── Push Notifications (VAPID) ───────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=       # chave pública VAPID gerada com web-push
VAPID_PRIVATE_KEY=                  # chave privada VAPID (manter server-side)

# ─── Features Flags ───────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_EMBLEM_UPLOAD=false  # Upload de emblema de liga (Could — false em produção inicial)

# ─── Node ────────────────────────────────────────────────────────────
NODE_ENV=production

# ─── Railway Mitigation (2026-05-06) ─────────────────────────────────
NEXT_PUBLIC_TICK_INTERVAL_MS=10000
NEXT_PUBLIC_STREAM_URL=https://stream.footstock.com.br
NEXT_PUBLIC_API_URL=https://api.footstock.com.br

# Resend — email transacional (forgot-password / reset por token)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@footstock.com.br
