# =====================================================================
# Foot Stock — Variáveis de Ambiente de Produção
# =====================================================================
# INSTRUÇÕES:
#   1. Copie este arquivo para .env.production.local (nunca commitar!)
#   2. Preencha TODOS os valores obrigatórios antes do deploy
#   3. Nunca compartilhe este arquivo ou seus valores
#   Gerado por: module-30-finalizacao / TASK-0 ST003 em 2026-04-01
# =====================================================================

# ─── Supabase (Produção — usar projeto DIFERENTE do staging) ─────────
DATABASE_URL=           # postgresql://[user]:[password]@[host]:[port]/[database]?sslmode=require
NEXT_PUBLIC_SUPABASE_URL=           # https://[project-id].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # chave anon pública — OK expor ao cliente
SUPABASE_SERVICE_ROLE_KEY=          # OBRIGATÓRIO: manter ONLY server-side, NUNCA NEXT_PUBLIC_

# ─── Redis / Upstash (Produção com TLS) ──────────────────────────────
UPSTASH_REDIS_REST_URL=             # https://[region]-[id].upstash.io (TLS automático)
UPSTASH_REDIS_REST_TOKEN=           # token do Upstash produção

# ─── Anthropic (Assessor IA) ─────────────────────────────────────────
ANTHROPIC_API_KEY=                  # sk-ant-... chave de produção (cuidado com billing)

# ─── Pagamentos — Produção (NÃO sandbox) ─────────────────────────────
# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=           # APP_USR-... chave de produção real

# PagSeguro
PAGOSEGURO_EMAIL=                   # email da conta PagSeguro de produção
PAGOSEGURO_TOKEN=                   # token da conta PagSeguro de produção

# PayPal
PAYPAL_CLIENT_ID=                   # Client ID de produção (não sandbox)
PAYPAL_CLIENT_SECRET=               # Client Secret de produção (não sandbox)

# ─── Sentry (Monitoramento de erros em produção) ─────────────────────
SENTRY_DSN=                         # https://[key]@[org].ingest.sentry.io/[project]
NEXT_PUBLIC_SENTRY_DSN=             # mesmo valor — exposto ao browser para capturar erros FE
SENTRY_AUTH_TOKEN=                  # token para source maps (somente CI/CD)
SENTRY_ORG=                         # slug da organização no Sentry
SENTRY_PROJECT=                     # slug do projeto no Sentry (ex: foot-stock)

# ─── App URL ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=                # https://foot-stock.com (URL de produção sem trailing slash)
NEXT_PUBLIC_SITE_URL=               # https://foot-stock.com (mesmo valor)

# ─── WebAuthn (Biometria) ─────────────────────────────────────────────
WEBAUTHN_RP_ID=                     # foot-stock.com (domínio sem https://)
WEBAUTHN_RP_NAME=                   # Foot Stock
WEBAUTHN_ORIGIN=                    # https://foot-stock.com

# ─── Segurança ────────────────────────────────────────────────────────
CPF_HASH_SALT=                      # OBRIGATÓRIO: string aleatória ≥32 chars, NUNCA mudar em produção

# ─── FlagCheck (Verificação de Maioridade ECA Digital) ───────────────
FLAGCHECK_API_URL=                  # URL da API FlagCheck de produção
FLAGCHECK_API_KEY=                  # Chave da API FlagCheck de produção

# ─── Cron e Tokens Internos ───────────────────────────────────────────
CRON_SECRET=                        # OBRIGATÓRIO: Bearer secret para /api/cron/* (min 32 chars)
INVITE_TOKEN_SECRET=                # OBRIGATÓRIO: JWT secret para tokens de convite de liga (min 32 chars)

# ─── Motor de Mercado (Railway) ───────────────────────────────────────
NEXT_PUBLIC_SOCKET_URL=             # https://[app].railway.app (URL do motor Node.js)

# ─── Push Notifications (VAPID) ───────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=       # chave pública VAPID gerada com web-push
VAPID_PRIVATE_KEY=                  # chave privada VAPID (manter server-side)

# ─── Features Flags ───────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_EMBLEM_UPLOAD=false  # Upload de emblema de liga (Could — false em produção inicial)

# ─── Node ────────────────────────────────────────────────────────────
NODE_ENV=production
