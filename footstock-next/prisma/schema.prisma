  @@map("nsm_daily_records")
}

// ─── Push Subscriptions (EP045/EP046 — VAPID web push) ───────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String   @map("p256dh")
  auth      String
  userAgent String?  @map("user_agent")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, active])
  @@map("push_subscriptions")
}

// ─── Motor: Matriz de Impacto de Notícias (Admin) ──────────────────────────

model ImpactMatrixConfig {
  id String @id @default(cuid())

  // Impacto spot máximo por categoria de notícia (0-1, representado como percentual)
  financeiraCritica    Decimal @default(0.05) @map("financeira_critica") @db.Decimal(5, 3)
  // ↑ 5% (0.050)
  esportivaMajoritaria Decimal @default(0.03) @map("esportiva_majoritaria") @db.Decimal(5, 3)
  // ↑ 3% (0.030)
  mercadoAtivos        Decimal @default(0.02) @map("mercado_ativos") @db.Decimal(5, 3)
  // ↑ 2% (0.020)
  integridadeSaude     Decimal @default(0.015) @map("integridade_saude") @db.Decimal(5, 3)
  // ↑ 1.5% (0.015)
  institucional        Decimal @default(0.01) @map("institucional") @db.Decimal(5, 3)
  // ↑ 1% (0.010)
  esportivaMenor       Decimal @default(0.005) @map("esportiva_menor") @db.Decimal(5, 3)
  // ↑ 0.5% (0.005)

  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@map("impact_matrix_configs")
}

// ─── Auditoria de transições de sessão de mercado ─────────────────────────────
// Rastreabilidade: T-008 (cron/session-transition)
// Usa String para fromSession/toSession pois os valores vêm do enum MarketSession
// (PRE_OPENING, TRADING, CLOSING_CALL, AFTER_MARKET, CLOSED) — distinto do SessionType do Prisma.

model MarketSessionLog {
  id           String   @id @default(cuid())
  fromSession  String   @map("from_session")
  toSession    String   @map("to_session")
  transitionAt DateTime @map("transition_at")

  @@index([transitionAt])
  @@map("market_session_logs")
}

// ─── Portal do Clube — ClubUser (credenciais separadas) ─────────────────────
// Rastreabilidade: US-025, TASK-015, MILESTONE-9

model ClubUser {
  id           String    @id @default(cuid())
  clubTicker   String    @map("club_ticker")
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  role         String    @default("VIEWER") @db.VarChar(20) // VIEWER only
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdBy    String    @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  asset   Asset @relation(fields: [clubTicker], references: [ticker])
  creator User  @relation("ClubUserCreator", fields: [createdBy], references: [id])

  accessLogs ClubAccessLog[]

  @@index([clubTicker])
  @@index([email])
  @@map("club_users")
}

model ClubAccessLog {
  id         String   @id @default(cuid())
  clubUserId String   @map("club_user_id")
  action     String   @db.VarChar(50) // LOGIN, LOGOUT, VIEW_DASHBOARD, VIEW_HISTORY
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  clubUser ClubUser @relation(fields: [clubUserId], references: [id], onDelete: Cascade)

  @@index([clubUserId])
  @@index([createdAt])
  @@map("club_access_logs")
}

// ─── Verificacao de Maioridade via CPF (T-023) ──────────────────────────────
// Historico completo de tentativas de verificacao de idade.
// CPF armazenado APENAS como hash SHA-256/HMAC — nunca em texto claro.

model AgeVerification {
  id         String             @id @default(cuid())
  userId     String             @map("user_id")
  cpfHash    String             @map("cpf_hash") @db.VarChar(64)
  isAdult    Boolean            @map("is_adult")
  method     VerificationMethod
  verifiedAt DateTime?          @map("verified_at")
  createdAt  DateTime           @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([cpfHash])
  @@map("age_verifications")
}

// T-019: Log de reset de saldo pelo admin (auditoria)
model BalanceResetLog {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  adminId         String   @map("admin_id")
  previousBalance Decimal  @map("previous_balance") @db.Decimal(18, 8)
  newBalance      Decimal  @map("new_balance") @db.Decimal(18, 8)
  planType        PlanType @map("plan_type")
  createdAt       DateTime @default(now()) @map("created_at")

  user  User @relation("BalanceResetTarget", fields: [userId], references: [id])
  admin User @relation("BalanceResetAdmin", fields: [adminId], references: [id])

  @@index([userId])
  @@index([adminId])
  @@index([createdAt])
  @@map("balance_reset_logs")
}
