generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────

enum PlanType {
  JOGADOR
  CRAQUE
  LENDA
}

enum OrderType {
  MARKET
  LIMIT
  STOP_LOSS
  TAKE_PROFIT
  OCO
  SCHEDULED
}

enum PositionSide {
  LONG
  SHORT
}

enum PositionStatus {
  OPEN
  CLOSED
}

enum FinancialType {
  TRADE
  BONUS
  DEPOSIT
  WITHDRAWAL
  SHORT_INTEREST
  MARGIN_BLOCKED
  SHORT_CLOSE
  LEVERAGE_INTEREST
  FEE
}

enum OrderSide {
  BUY
  SELL
}

enum OrderStatus {
  OPEN
  FILLED
  CANCELLED
  EXPIRED
  PARTIAL
}

enum AdminRole {
  SUPER_ADMIN
  ADMINISTRADOR
  MONITOR
  EDITOR
  MODERADOR
  CLUB_PARTNER
}

enum InvestorProfile {
  CONSERVADOR // legacy
  MODERADO // legacy
  ARROJADO // legacy
  ESPECULADOR // legacy
  INICIANTE
  INTERMEDIARIO
  AVANCADO
  FA
}

enum LeagueType {
  PUBLICA
  AMIGOS
  PRO
}

enum TrophyType {
  PRO_LEAGUE_WINNER // 1o lugar
  PRO_LEAGUE_RUNNER_UP // 2o lugar
  PRO_LEAGUE_THIRD // 3o lugar
}

enum NotificationType {
  // Alinhado com NOTIFICATION-SPEC.md (23 tipos — T-014)
  ORDER_EXECUTED
  ORDER_CANCELLED
  // Margin Call: dois thresholds distintos (50% = aviso, 80% = alerta crítico)
  MARGIN_CALL_WARNING // 50% — aviso não urgente
  MARGIN_CALL_ALERT // 80% — alerta crítico, ignora quiet hours
  CIRCUIT_BREAKER
  NEWS_FAVORITE_CLUB
  PAYMENT_CONFIRMED
  PAYMENT_FAILED
  PLAN_CANCEL_ALERT
  DIVIDEND_CREDITED
  BONUS_CREDITED
  // Bônus com carência (T-021 / CDC Art. 49)
  BONUS_SCHEDULED // bônus agendado — creditado em T+7 dias após upgrade
  BONUS_CANCELLED // bônus cancelado — usuário cancelou dentro do período de carência
  LEAGUE_RESULT
  ADMIN_BROADCAST
  // Trava de cancelamento
  CANCELLATION_LOCK_ACTIVE
  CANCELLATION_LOCK_LIQUIDATED
  // Sistema de afiliados (T-001)
  AFFILIATE_COMMISSION_EARNED
  AFFILIATE_INVITE_JOINED
  // Segurança e conta (T-014)
  PASSWORD_RESET // email only, urgente
  LGPD_EXPORT_READY // email only
  ACCOUNT_DELETED // email only, urgente
  BRUTE_FORCE_BLOCKED // email only, urgente
  // Sistema
  SYSTEM_MAINTENANCE // in-app + push
  REFERRAL_JOINED // in-app (para quem foi indicado)
  // Verificação de maioridade (T-023)
  AGE_VERIFICATION_PENDING // in-app — FlagCheck indisponível no cadastro
  AGE_VERIFICATION_COMPLETED // in-app — verificação concluída com sucesso
  // Saldo e financeiro
  BALANCE_ZERO // saldo FS$ zerou (T-019)
  BALANCE_RESET // saldo resetado pelo admin (T-019)
  // Moderação de fórum (T-028)
  POST_FLAGGED // in-app para MODERADOR+ — post aguarda revisão
  POST_REJECTED // in-app para o autor — post foi rejeitado
}

enum NotificationChannel {
  IN_APP
  PUSH
  EMAIL
}

enum ImpactCategory {
  POSITIVE // legacy
  NEGATIVE // legacy
  NEUTRAL // legacy
  FINANCEIRA_CRITICA // +/-5%
  ESPORTIVA_MAJORITARIA // +/-3%
  MERCADO_ATIVOS // +/-2%
  INTEGRIDADE_SAUDE // +/-1.5%
  INSTITUCIONAL // +/-1%
  ESPORTIVA_MENOR // +/-0.5%
}

enum Sentiment {
  BULLISH
  BEARISH
  NEUTRAL
}

enum Division {
  SERIE_A
  SERIE_B
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum WebhookAuditStatus {
  ACCEPTED
  REJECTED
  DUPLICATE
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  TRIAL
  EXPIRED
  SUSPENDED
  CANCELLATION_LOCK
  CANCELLED
  PAST_DUE // legacy
  TRIALING // legacy
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum SubscriptionGateway {
  MERCADO_PAGO
  PAGSEGURO
  PAYPAL
}

enum SubscriptionPeriod {
  MONTHLY
  YEARLY
}

enum SessionType {
  PRE_MARKET
  REGULAR
  CLOSING_CALL
  AFTER_MARKET
  CLOSED
}

enum ConsentPurpose {
  ESSENTIAL
  ANALYTICS
  MARKETING
  DATA_TERCEIROS
  AGE_VERIFICATION
  SPONSORED_LEAGUES
}

enum VerificationMethod {
  FLAGCHECK
  AUTODECLARATION
  ADMIN_OVERRIDE
}

enum ExportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── Models ───────────────────────────────────────────────────────

model User {
  id                      String           @id @default(cuid())
  email                   String           @unique
  name                    String
  phone                   String?
  cpfHash                 String           @unique @map("cpf_hash")
  birthDate               DateTime?        @map("birth_date") @db.Date
  planType                PlanType         @default(JOGADOR) @map("plan_type")
  status                  UserStatus       @default(ACTIVE)
  adminRole               AdminRole?       @map("admin_role")
  investorProfile         InvestorProfile? @map("investor_profile")
  tourCompleted           Boolean          @default(false) @map("tour_completed")
  tourSkippedAt           DateTime?        @map("tour_skipped_at")
  favoriteClub            String?          @map("favorite_club")
  fsBalance               Decimal          @default(10000) @map("fs_balance") @db.Decimal(18, 2)
  marginBlocked           Decimal          @default(0) @map("margin_blocked") @db.Decimal(18, 2)
  ageVerificationPending  Boolean          @default(false) @map("age_verification_pending")
  referredByCode          String?          @map("referred_by_code")
  favoriteClubDisplayName String?          @map("favorite_club_display_name")
  bio                     String?          @db.VarChar(300)
  suspendedAt             DateTime?        @map("suspended_at")
  suspensionReason        String?          @map("suspension_reason") @db.VarChar(500)
  userType                String           @default("NORMAL") @map("user_type")
  version                 Int              @default(0)
  emailVerified           DateTime?        @map("email_verified")
  image                   String?
  createdAt               DateTime         @default(now()) @map("created_at")
  updatedAt               DateTime         @updatedAt @map("updated_at")

  accounts                 Account[]
  sessions                 Session[]
  orders                   Order[]
  positions                Position[]
  transactions             Transaction[]
  subscriptions            Subscription[]
  payments                 Payment[]
  notifications            Notification[]
  notificationPreferences  NotificationPreference[]
  consents                 Consent[]
  leagueMemberships        LeagueMember[]
  forumPosts               ForumPost[]
  globalForumPosts         GlobalForumPost[]
  forumLikes               ForumLike[]
  dataAccessLogs           DataAccessLog[]
  dataExportJobs           DataExportJob[]
  createdLeagues           League[]                   @relation("LeagueCreator")
  adminActions             AdminMarketAction[]        @relation("AdminActor")
  dividends                Dividend[]
  yieldDifferentialPending YieldDifferentialPending[]
  glossaryInteractions     GlossaryInteraction[]
  affiliateCode            AffiliateCode?
  affiliateReferrals       AffiliateTransaction[]     @relation("AffiliateReferredUser")
  pushSubscriptions        PushSubscription[]
  leagueScoreEvents        LeagueScoreEvent[]
  leagueDailyRanks         LeagueDailyRank[]
  leagueTrophies           LeagueTrophy[]
  moderationActions        ModerationAction[]         @relation("ModerationActions")
  createdClubUsers         ClubUser[]                 @relation("ClubUserCreator")
  ageVerifications         AgeVerification[]
  balanceResets            BalanceResetLog[]          @relation("BalanceResetTarget")
  balanceResetsMade        BalanceResetLog[]          @relation("BalanceResetAdmin")

  @@map("users")
}

// ─── Auth.js v5 (NXAUTH-02) ────────────────────────────────────────
// Tabelas requeridas pelo @auth/prisma-adapter para account linking,
// sessions DB e magic-link tokens. Acoplado via wrapper PrismaAdapter
// (NXAUTH-03A) que previne auto-create de User sem cpfHash.

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refreshToken      String? @map("refresh_token")
  accessToken       String? @map("access_token")
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token")
  sessionState      String? @map("session_state")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Asset {
  id             String   @id @default(cuid())
  ticker         String   @unique
  /// Nome fictício exibido na plataforma (ex: "Urubu da Gavea FC"). Mapeado para coluna "name".
  displayName    String   @map("name")
  /// Nome real do clube (ex: "Flamengo") — uso server-side e admin APENAS. NUNCA retornar em endpoints públicos.
  realName       String?  @map("real_name")
  clubSlug       String   @unique @map("club_slug")
  division       Division
  cluster        String // A_TOP | A_MID | A_SMALL | B_LIQUID | B_ILLIQ
  currentPrice   Decimal  @map("current_price") @db.Decimal(18, 8)
  openPrice      Decimal  @map("open_price") @db.Decimal(18, 8)
  closePrice     Decimal  @map("close_price") @db.Decimal(18, 8)
  fairValue      Decimal  @default(0) @map("fair_value") @db.Decimal(18, 8)
  volume         BigInt   @default(0)
  marketCap      Decimal  @map("market_cap") @db.Decimal(18, 2)
  currentSupply  BigInt   @default(1000000) @map("current_supply")
  totalShares    BigInt   @default(1000000) @map("total_shares")
  isActive       Boolean  @default(true) @map("is_active")
  isHalted       Boolean  @default(false) @map("is_halted")
  haltReason     String?  @map("halt_reason")
  sentiment      String   @default("NEUTRAL") // BULLISH | BEARISH | NEUTRAL
  financials     Json?    @db.JsonB
  colorPrimary   String   @map("color_primary")
  colorSecondary String   @map("color_secondary")
  logoUrl        String?  @map("logo_url")
  /// Aliases internos de busca (nomes reais, apelidos, siglas) — uso server-side APENAS.
  /// NUNCA retornar ao cliente. Permite pesquisar "Flamengo" e encontrar URU3.
  searchText     String   @default("") @map("search_text")
  /// Nome do tecnico atual — server-only. Usado APENAS no fallback de matching
  /// de noticias (segunda camada) quando a primeira passada nao identifica time.
  /// NUNCA expor em endpoints publicos.
  coachName      String?  @map("coach_name")
  /// Lista de jogadores (separados por virgula) — server-only. Usado APENAS no
  /// fallback de matching de noticias. NUNCA expor em endpoints publicos.
  players        String   @default("") @map("players")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  priceHistory PriceHistory[]
  orders       Order[]
  positions    Position[]
  transactions Transaction[]
  sponsors     Sponsor[]
  adminActions AdminMarketAction[]
  clubUsers    ClubUser[]
  aliases      AssetAlias[]

  @@map("assets")
}

/// Tabela de aliases de ticker — mapeia códigos do mundo real (FLA3) para tickers fictícios do sistema (URU3).
/// Resolução transparente: cliente envia FLA3, servidor responde com dados de URU3.
model AssetAlias {
  id          String   @id @default(cuid())
  /// Alias normalizado em maiúsculas (ex: "FLA3", "FLA4", "FLM3")
  alias       String   @unique
  /// Ticker canônico do ativo no sistema (ex: "URU3")
  assetTicker String   @map("asset_ticker")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  asset Asset @relation(fields: [assetTicker], references: [ticker])

  @@index([alias, isActive])
  @@index([assetTicker])
  @@map("asset_aliases")
}

model Order {
  id                 String      @id @default(cuid())
  userId             String      @map("user_id")
  assetId            String      @map("asset_id")
  type               OrderType
  side               OrderSide
  status             OrderStatus @default(OPEN)
  quantity           Int
  price              Decimal?    @db.Decimal(18, 8)
  executedPrice      Decimal?    @map("executed_price") @db.Decimal(18, 8)
  fee                Decimal     @default(0) @db.Decimal(18, 8)
  expiresAt          DateTime?   @map("expires_at")
  scheduledAt        DateTime?   @map("scheduled_at")
  groupId            String?     @map("group_id")
  leverageMultiplier Int         @default(1) @map("leverage_multiplier")
  executedAt         DateTime?   @map("executed_at")
  version            Int         @default(0)
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id])
  asset        Asset         @relation(fields: [assetId], references: [id])
  transactions Transaction[]

  @@index([userId])
  @@index([assetId])
  @@index([status])
  @@index([userId, status])
  @@index([groupId])
  @@map("orders")
}

model Position {
  id                 String         @id @default(cuid())
  userId             String         @map("user_id")
  assetId            String         @map("asset_id")
  quantity           Int
  avgPrice           Decimal        @map("avg_price") @db.Decimal(18, 8)
  totalInvested      Decimal        @map("total_invested") @db.Decimal(18, 2)
  side               PositionSide   @default(LONG)
  status             PositionStatus @default(OPEN)
  marginBlocked      Decimal        @default(0) @map("margin_blocked") @db.Decimal(18, 2)
  leverageMultiplier Int            @default(1) @map("leverage_multiplier")
  leverageAmount     Decimal        @default(0) @map("leverage_amount") @db.Decimal(18, 2)
  dailyInterestRate  Decimal        @default(0) @map("daily_interest_rate") @db.Decimal(10, 6)
  interestAccrued    Decimal        @default(0) @map("interest_accrued") @db.Decimal(18, 2)
  openedAt           DateTime?      @map("opened_at")
  version            Int            @default(0)
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id])
  asset Asset @relation(fields: [assetId], references: [id])

  @@index([userId])
  @@index([userId, status])
  @@map("positions")
}

model Transaction {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  // Nullable para lançamentos sem ativo (BONUS, DIVIDEND, DEPOSIT, WITHDRAWAL)
  assetId       String?       @map("asset_id")
  orderId       String?       @map("order_id")
  // Nullable para lançamentos financeiros sem tipo de ordem (BONUS, etc.)
  type          OrderType?
  financialType FinancialType @default(TRADE) @map("financial_type")
  side          OrderSide?
  quantity      Int?
  price         Decimal?      @db.Decimal(18, 8)
  fee           Decimal?      @db.Decimal(18, 8)
  totalAmount   Decimal       @map("total_amount") @db.Decimal(18, 2)
  fsAmount      Decimal?      @map("fs_amount") @db.Decimal(18, 2)
  balanceBefore Decimal?      @map("balance_before") @db.Decimal(18, 2)
  balanceAfter  Decimal?      @map("balance_after") @db.Decimal(18, 2)
  createdAt     DateTime      @default(now()) @map("created_at")

  user  User   @relation(fields: [userId], references: [id])
  asset Asset? @relation(fields: [assetId], references: [id])
  order Order? @relation(fields: [orderId], references: [id])

  @@index([userId])
  @@index([assetId])
  @@index([userId, createdAt])
  @@map("transactions")
}

model PriceHistory {
  id          String      @id @default(cuid())
  assetId     String      @map("asset_id")
  timestamp   DateTime
  open        Decimal     @db.Decimal(18, 8)
  high        Decimal     @db.Decimal(18, 8)
  low         Decimal     @db.Decimal(18, 8)
  close       Decimal     @db.Decimal(18, 8)
  volume      BigInt      @default(0)
  sessionType SessionType @map("session_type")
  source      String      @default("REAL") @map("source") // 'GBM' | 'REAL'

  asset Asset @relation(fields: [assetId], references: [id])

  @@index([assetId])
  @@index([assetId, timestamp])
  @@index([assetId, source])
  @@map("price_history")
}

model Subscription {
  id                          String              @id @default(cuid())
  userId                      String              @map("user_id")
  planType                    PlanType            @map("plan_type")
  previousPlanType            PlanType?           @map("previous_plan_type") // G-02: bônus diferencial de upgrade
  gateway                     SubscriptionGateway
  period                      SubscriptionPeriod
  amount                      Int // centavos BRL — NUNCA Float (PCI-DSS)
  status                      SubscriptionStatus  @default(PENDING)
  startsAt                    DateTime            @map("starts_at")
  expiresAt                   DateTime            @map("expires_at")
  cancelledAt                 DateTime?           @map("cancelled_at")
  cancellationLockStartedAt   DateTime?           @map("cancellation_lock_started_at")
  cancellationLockExpiresAt   DateTime?           @map("cancellation_lock_expires_at") // T+7d: cancelamento final
  forcedLiquidationAt         DateTime?           @map("forced_liquidation_at") // T+48h: liquidacao de posicoes restritas
  forcedLiquidationExecutedAt DateTime?           @map("forced_liquidation_executed_at") // idempotencia do cron T+48h
  bonusAmount                 Decimal?            @map("bonus_amount") @db.Decimal(18, 2) // T-021: valor imutável do bônus agendado
  bonusScheduledAt            DateTime?           @map("bonus_scheduled_at")
  bonusCreditedAt             DateTime?           @map("bonus_credited_at")
  renewalReminderSentAt       DateTime?           @map("renewal_reminder_sent_at") // G-01: lembrete 7 dias antes do vencimento
  refundRequested             Boolean             @default(false) @map("refund_requested")
  createdAt                   DateTime            @default(now()) @map("created_at")
  updatedAt                   DateTime            @updatedAt @map("updated_at")

  user            User             @relation(fields: [userId], references: [id])
  payments        Payment[]
  dunningAttempts DunningAttempt[]

  @@index([userId, status])
  @@index([expiresAt, status])
  @@index([cancellationLockExpiresAt, status])
  @@index([forcedLiquidationAt, status, forcedLiquidationExecutedAt])
  @@index([renewalReminderSentAt, status])
  @@map("subscriptions")
}

model Payment {
  id                   String              @id @default(cuid())
  userId               String              @map("user_id")
  subscriptionId       String              @map("subscription_id")
  amount               Int // centavos BRL — NUNCA Float (PCI-DSS)
  gateway              SubscriptionGateway
  gatewayTransactionId String              @unique @map("gateway_transaction_id") // idempotência de webhook (PAYMENT_052)
  gatewayMeta          Json?               @map("gateway_meta") // metadados não sensíveis do gateway (sem PAN/CVV)
  status               PaymentStatus       @default(PENDING)
  processedAt          DateTime?           @map("processed_at") // preenchido ao processar webhook
  createdAt            DateTime            @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id])
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([userId])
  @@index([gatewayTransactionId])
  @@map("payments")
}

// ─── Dunning: tentativas de cobrança D+1/D+3/D+7 ─────────────────────────────

model DunningAttempt {
  id             String              @id @default(cuid())
  subscriptionId String              @map("subscription_id")
  attemptNumber  Int                 @map("attempt_number") // 1, 2 ou 3
  gateway        SubscriptionGateway
  status         PaymentStatus       @default(PENDING)
  scheduledAt    DateTime            @map("scheduled_at") // D+1, D+3, D+7
  processedAt    DateTime?           @map("processed_at")
  errorMessage   String?             @map("error_message")
  createdAt      DateTime            @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@unique([subscriptionId, attemptNumber])
  @@index([scheduledAt, status])
  @@map("dunning_attempts")
}

// ─── Auditoria de webhooks (PCI-DSS req. 6 — 90 dias) ────────────────────────

model WebhookAuditLog {
  id             String              @id @default(cuid())
  gateway        SubscriptionGateway
  eventType      String?             @map("event_type") // PAYMENT_CONFIRMED | PAYMENT_FAILED | REFUND_COMPLETED | null
  transactionId  String?             @map("transaction_id")
  subscriptionId String?             @map("subscription_id")
  status         WebhookAuditStatus // ACCEPTED | REJECTED | DUPLICATE
  hmacValid      Boolean             @map("hmac_valid")
  ipAddress      String?             @map("ip_address")
  errorMessage   String?             @map("error_message")
  processedAt    DateTime            @default(now()) @map("processed_at")

  @@index([gateway, status])
  @@index([processedAt]) // para cleanup de retenção 90 dias
  @@index([transactionId])
  @@map("webhook_audit_logs")
}

model News {
  id          String         @id @default(cuid())
  title       String
  content     String         @db.Text
  impact      ImpactCategory
  sentiment   Sentiment
  ticker      String? // ticker do ativo vinculado (ex: "URU3")
  // Array de IDs de ativos relacionados (suporte nativo PostgreSQL)
  assetIds    String[]       @map("asset_ids")
  source      String?
  isPublished Boolean        @default(false) @map("is_published")
  publishedAt DateTime?      @map("published_at")
  isArchived  Boolean        @default(false) @map("is_archived")
  archivedAt  DateTime?      @map("archived_at")
  clicks      Int            @default(0)
  author      String         @default("admin")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@index([publishedAt])
  @@index([isPublished])
  @@index([isArchived])
  @@map("news")
}

model NewsSourceWhitelist {
  id        String   @id @default(cuid())
  domain    String   @unique
  addedBy   String   @map("added_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("news_source_whitelist")
}

model SponsorBanner {
  id               String    @id @default(cuid())
  title            String
  company          String
  position         String    @default("home_top")
  imageUrl         String?   @map("image_url")
  linkUrl          String?   @map("link_url")
  width            Int?
  height           Int?
  isActive         Boolean   @default(true) @map("is_active")
  clicks           Int       @default(0)
  impressions      Int       @default(0)
  color            String    @default("#00B1EA")
  ctaText          String    @default("Saiba mais") @map("cta_text")
  ctaColor         String    @default("#00B1EA") @map("cta_color")
  sponsorId        String?   @map("sponsor_id")
  startDate        DateTime? @map("start_date")
  endDate          DateTime? @map("end_date")
  imageDesktopUrl  String?   @map("image_desktop_url")
  imageMobileUrl   String?   @map("image_mobile_url")
  imageVerticalUrl String?   @map("image_vertical_url")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  sponsor Sponsor? @relation(fields: [sponsorId], references: [id], onDelete: SetNull)
  leagues League[]

  @@index([isActive])
  @@index([position, isActive])
  @@map("sponsor_banners")
}

model SponsoredLeague {
  id              String   @id @default(cuid())
  name            String
  company         String
  prize           String   @default("FS$0") // legacy - prêmio resumo
