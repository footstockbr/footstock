// Foot Stock — Prisma Schema
// Gerado por /back-end-build em 2026-03-28
// Referência: output/docs/foot-stock/project/LLD.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum PositionStatus {
  OPEN
  CLOSED
}

enum WebhookAuditStatus {
  ACCEPTED
  REJECTED
  DUPLICATE
}

enum ConsentPurpose {
  ESSENTIAL
  ANALYTICS
  MARKETING
  DATA_TERCEIROS
  AGE_VERIFICATION
}

enum ExportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum UserType {
  NORMAL
  TIME_PARCEIRO
  INFLUENCIADOR
}

enum InvestorProfile {
  INICIANTE
  INTERMEDIARIO
  AVANCADO
  FA_FUTEBOL
}

enum PlanType {
  JOGADOR
  CRAQUE
  LENDA
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  ADMINISTRADOR
  MONITOR
  EDITOR
  MODERADOR
  CLUB_PARTNER
}

enum OrderType {
  MARKET
  LIMIT
  OCO
  SHORT
  SCHEDULED
}

enum OrderSide {
  BUY
  SELL
}

enum OrderStatus {
  PENDING
  OPEN
  EXECUTED
  FILLED
  CANCELLED
  EXPIRED
  PARTIAL
}

enum PositionSide {
  LONG
  SHORT
}

enum AssetDivision {
  A
  B
}

enum AssetSentiment {
  BULLISH
  NEUTRO
  BEARISH
}

enum TransactionType {
  BUY
  SELL
  FEE
  DIVIDEND
  MARGIN_CALL
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING_PAYMENT
  CANCELLATION_LOCK
}

enum PaymentGateway {
  MERCADO_PAGO
  PAGSEGURO
  PAYPAL
}

enum PaymentPeriod {
  MONTHLY
  ANNUAL
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
  CHARGEBACK
}

enum ImpactCategory {
  RESULTADO_ESPORTIVO
  CONTRATACAO
  FINANCEIRO
  LESAO
  SUSPENSAO
  INSTITUCIONAL
}

enum LeagueType {
  PUBLICA
  AMIGOS
  PRO
}

enum LeagueDivision {
  BRONZE
  PRATA
  OURO
  ABERTA
}

enum LeagueStatus {
  PENDING
  ACTIVE
  FINISHED
}

enum PostStatus {
  ACTIVE
  REMOVED
  FLAGGED
}

enum AffiliateType {
  TIME_PARCEIRO
  INFLUENCIADOR
}

enum CommissionType {
  ROYALTY_PERCENTAGE
  NEGOTIATED_COMMISSION
}

enum AffiliateTransactionType {
  SIGNUP
  SUBSCRIPTION_RENEWAL
  UPGRADE
}

enum AffiliateTransactionStatus {
  PENDING
  PAID
  CANCELLED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                      String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                   String          @unique @db.VarChar(255)
  cpfHash                 String          @unique @db.Char(64)
  name                    String          @db.VarChar(120)
  phone                   String?         @db.VarChar(20)
  birthDate               DateTime        @db.Date
  favoriteClub            String          @db.VarChar(10)
  favoriteClubDisplayName String?         @db.VarChar(100)
  userType                UserType        @default(NORMAL)
  referredByCode          String?         @db.VarChar(20)
  investorProfile         InvestorProfile
  planType                PlanType        @default(JOGADOR)
  fsBalance               Decimal         @default(2000.00) @db.Decimal(12, 2)
  marginBlocked           Decimal         @default(0.00) @db.Decimal(12, 2)
  tourCompleted           Boolean         @default(false)
  ageVerificationPending  Boolean         @default(false)
  adminRole               AdminRole?
  status                  UserStatus      @default(ACTIVE)
  bio                     String?         @db.VarChar(300)
  suspendedAt             DateTime?
  suspensionReason        String?         @db.VarChar(500)
  version                 Int             @default(0)
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  orders               Order[]
  positions            Position[]
  transactions         Transaction[]
  notifications        Notification[]
  forumPosts           ForumPost[]
  globalForumPosts     GlobalForumPost[]
  forumLikes           ForumLike[]
  consents             Consent[]
  dataAccessLogs       DataAccessLog[]  @relation("UserDataAccessLogs")
  accessedDataLogs     DataAccessLog[]  @relation("AdminDataAccessLogs")
  subscription         Subscription?
  affiliateCodes       AffiliateCode[]
  affiliateTransactions AffiliateTransaction[] @relation("ReferredUser")
  pushSubscriptions    PushSubscription[]
  adminActions         AdminMarketAction[]
  leagueMembers        LeagueMember[]
  glossaryInteractions GlossaryInteraction[]
  dataExportJobs       DataExportJob[]
  dividends            Dividend[]
  leagueScoreEvents    LeagueScoreEvent[]

  @@index([email])
  @@index([cpfHash])
  @@index([planType])
  @@index([userType])
  @@index([referredByCode])
  @@map("users")
}

model Asset {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticker         String         @unique @db.VarChar(10)
  name           String         @db.VarChar(100)
  realName       String         @db.VarChar(80)
  displayName    String         @db.VarChar(100)
  division       AssetDivision
  currentPrice   Decimal        @db.Decimal(10, 4)
  fairValue      Decimal        @db.Decimal(10, 4)
  openPrice      Decimal        @default(0) @db.Decimal(10, 4)
  closePrice     Decimal        @default(0) @db.Decimal(10, 4)
  cluster        String         @default("A_TOP") @db.VarChar(20)
  volume         BigInt         @default(0)
  currentSupply  BigInt
  totalShares    BigInt
  isActive       Boolean        @default(true)
  isHalted       Boolean        @default(false)
  haltReason     String?        @db.VarChar(100)
  colorPrimary   String         @default("#000000") @db.VarChar(20)
  colorSecondary String         @default("#FFFFFF") @db.VarChar(20)
  colors         Json
  financials     Json
  sentiment      AssetSentiment @default(NEUTRO)
  updatedAt      DateTime       @updatedAt

  orders       Order[]
  positions    Position[]
  priceHistory PriceHistory[]
  news         News[]

  @@index([ticker])
  @@index([division])
  @@map("assets")
}

model Order {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String      @db.Uuid
  ticker          String      @db.VarChar(10)
  type            OrderType
  side            OrderSide
  quantity        Decimal     @db.Decimal(14, 4)
  price           Decimal?    @db.Decimal(10, 4)
  executedPrice   Decimal?    @db.Decimal(10, 4)
  status          OrderStatus @default(PENDING)
  stopLossPrice   Decimal?    @db.Decimal(10, 4)
  takeProfitPrice Decimal?    @db.Decimal(10, 4)
  scheduledAt     DateTime?
  feeAmount       Decimal?    @db.Decimal(8, 2)
  leverageMultiplier Int      @default(1)
  executedAt      DateTime?
  expiresAt       DateTime?
  groupId         String?     @db.VarChar(50)
  version         Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  asset        Asset         @relation(fields: [ticker], references: [ticker])
  transactions Transaction[]

  @@index([userId, status])
  @@index([ticker, status])
  @@index([groupId])
  @@map("orders")
}

model Position {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String       @db.Uuid
  ticker              String       @db.VarChar(10)
  quantity            Decimal      @db.Decimal(14, 4)
  avgPrice            Decimal      @db.Decimal(10, 4)
  totalInvested       Decimal      @default(0) @db.Decimal(12, 2)
  side                PositionSide
  status              PositionStatus @default(OPEN)
  marginBlocked       Decimal      @default(0) @db.Decimal(12, 2)
  leverageMultiplier  Decimal      @default(1.0) @db.Decimal(3, 1)
  leverageAmount      Decimal      @default(0.0) @db.Decimal(12, 2)
  dailyInterestRate   Decimal      @default(0.0) @db.Decimal(6, 4)
  interestAccrued     Decimal      @default(0.0) @db.Decimal(10, 2)
  openedAt            DateTime?
  version             Int          @default(0)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  asset Asset @relation(fields: [ticker], references: [ticker])

  @@index([userId])
  @@index([userId, status])
  @@index([ticker])
  @@map("positions")
}

model Transaction {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String          @db.Uuid
  orderId       String?         @db.Uuid
  ticker        String          @db.VarChar(10)
  type          TransactionType
  amount        Decimal         @db.Decimal(14, 4)
  fsAmount      Decimal         @db.Decimal(12, 2)
  balanceBefore Decimal         @db.Decimal(12, 2)
  balanceAfter  Decimal         @db.Decimal(12, 2)
  createdAt     DateTime        @default(now())

  user  User   @relation(fields: [userId], references: [id])
  order Order? @relation(fields: [orderId], references: [id])

  @@index([userId])
  @@index([ticker])
  @@map("transactions")
}

model PriceHistory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticker    String   @db.VarChar(10)
  open      Decimal  @db.Decimal(10, 4)
  high      Decimal  @db.Decimal(10, 4)
  low       Decimal  @db.Decimal(10, 4)
  close     Decimal  @db.Decimal(10, 4)
  volume    Decimal  @db.Decimal(18, 4)
  period    String   @db.VarChar(4)
  timestamp DateTime

  asset Asset @relation(fields: [ticker], references: [ticker])

  @@index([ticker, period, timestamp(sort: Desc)])
  @@map("price_history")
}

model Subscription {
  id                        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                    String             @unique @db.Uuid
  planType                  PlanType
  previousPlanType          PlanType?
  gateway                   PaymentGateway
  period                    PaymentPeriod
  amount                    Int                @default(0)
  status                    SubscriptionStatus
  startsAt                  DateTime
  expiresAt                 DateTime?
  trialEndsAt               DateTime?
  cancelledAt               DateTime?
  cancellationLockExpiresAt DateTime?
  bonusScheduledAt          DateTime?
  bonusCreditedAt           DateTime?
  renewalReminderSentAt     DateTime?
  refundRequested           Boolean            @default(false)
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  user                  User                   @relation(fields: [userId], references: [id])
  payments              Payment[]
  affiliateTransactions AffiliateTransaction[]
  dunningAttempts       DunningAttempt[]

  @@index([expiresAt, status])
  @@index([cancellationLockExpiresAt, status])
  @@index([renewalReminderSentAt, status])
  @@map("subscriptions")
}

model Payment {
  id                   String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionId       String         @db.Uuid
  gateway              PaymentGateway
  gatewayTransactionId String         @unique @db.VarChar(255)
  amount               Decimal        @db.Decimal(10, 2)
  currency             String         @default("BRL") @db.VarChar(3)
  status               PaymentStatus
  gatewayMeta          Json?
  processedAt          DateTime?
  createdAt            DateTime       @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@map("payments")
}

model News {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title          String         @db.VarChar(255)
  content        String?        @db.Text
  source         String         @db.VarChar(100)
  url            String         @db.VarChar(500)
  ticker         String         @db.VarChar(10)
  assetIds       String[]
  sentiment      Decimal        @db.Decimal(4, 3)
  impactCategory ImpactCategory
  isPublished    Boolean        @default(true)
  status         String         @default("published") @db.VarChar(20)
  publishedAt    DateTime
  injectedAt     DateTime       @default(now())
  createdAt      DateTime       @default(now())

  asset Asset @relation(fields: [ticker], references: [ticker])

  @@index([ticker])
  @@index([status])
  @@index([isPublished])
  @@index([injectedAt(sort: Desc)])
  @@map("news")
}

model League {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String         @db.VarChar(60)
  slug      String         @unique @db.VarChar(80)
  type      LeagueType
  division  LeagueDivision
  duration  String         @db.VarChar(12) // '1S' | '1M' | 'TEMPORADA'
  sponsorId String?        @db.Uuid
  createdBy String?        @db.Uuid
  startsAt  DateTime
  endsAt    DateTime?
  status    LeagueStatus   @default(ACTIVE)
  createdAt DateTime       @default(now())

  sponsor     Sponsor?           @relation(fields: [sponsorId], references: [id])
  members     LeagueMember[]
  scoreEvents LeagueScoreEvent[]

  @@index([type, status])
  @@map("leagues")
}

model LeagueMember {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leagueId       String    @db.Uuid
  userId         String    @db.Uuid
  score          Decimal   @default(0) @db.Decimal(12, 4) // = finalScore
  rank           Int       @default(0)
  scoreBreakdown Json?     // ScoreBreakdown completo em JSON
  joinedAt       DateTime  @default(now())
  lastScoreAt    DateTime?
  updatedAt      DateTime  @updatedAt

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leagueId, userId])
  @@index([leagueId, score(sort: Desc)])
  @@map("league_members")
}

model GlossaryInteraction {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  termSlug  String   @db.VarChar(100)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("glossary_interactions")
}

model ForumPost {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String     @db.Uuid
  content   String     @db.VarChar(280)
  ticker    String?    @db.VarChar(10)
  status    PostStatus @default(ACTIVE)
  likes     Int        @default(0)
  flagged   Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([ticker])
  @@index([status])
  @@map("forum_posts")
}

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  type      String   @db.VarChar(40)
  title     String   @db.VarChar(120)
  body      String   @db.VarChar(500)
  read      Boolean  @default(false)
  isRead    Boolean  @default(false)
  data      Json?
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([userId, isRead])
  @@map("notifications")
}

model Consent {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String         @db.Uuid
  purpose   ConsentPurpose
  granted   Boolean        @default(true)
  grantedAt DateTime       @default(now())
  ipAddress String?        @db.VarChar(45)
  userAgent String?        @db.VarChar(255)
  revoked   Boolean        @default(false)
  revokedAt DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, purpose])
  @@index([userId])
  @@map("consents")
}

model DataAccessLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid
  accessedBy  String   @db.Uuid
  action      String   @db.VarChar(60)
  dataType    String?  @db.VarChar(60)
  endpoint    String?  @db.VarChar(255)
  details     Json?
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now())

  user     User @relation("UserDataAccessLogs", fields: [userId], references: [id])
  accessor User @relation("AdminDataAccessLogs", fields: [accessedBy], references: [id])

  @@index([userId])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([timestamp(sort: Desc)])
  @@map("data_access_logs")
}

model Sponsor {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(120)
  banners   Json?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  leagues League[]

  @@map("sponsors")
}

model AdminMarketAction {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminId      String   @db.Uuid
  action       String   @db.VarChar(40)
  targetTicker String?  @db.VarChar(10)
  details      Json?
  timestamp    DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([timestamp(sort: Desc)])
  @@map("admin_market_actions")
}

model AffiliateCode {
  id                   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String        @db.Uuid
  code                 String        @unique @db.VarChar(20)
  affiliateType        AffiliateType
  commissionPercentage Decimal       @db.Decimal(5, 2)
  bankData             Json?
  active               Boolean       @default(true)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  user         User                   @relation(fields: [userId], references: [id])
  transactions AffiliateTransaction[]

  @@map("affiliate_codes")
}

model AffiliateTransaction {
  id                String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  affiliateCodeId   String                     @db.Uuid
  referredUserId    String                     @db.Uuid
  subscriptionId    String                     @db.Uuid
  transactionType   AffiliateTransactionType
  amount            Decimal                    @db.Decimal(10, 2)
  status            AffiliateTransactionStatus @default(PENDING)
  paidAt            DateTime?
  createdAt         DateTime                   @default(now())

  affiliateCode AffiliateCode @relation(fields: [affiliateCodeId], references: [id])
  referredUser  User          @relation("ReferredUser", fields: [referredUserId], references: [id])
  subscription  Subscription  @relation(fields: [subscriptionId], references: [id])

  @@map("affiliate_transactions")
}

model PushSubscription {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid
  endpoint    String   @unique @db.VarChar(500)
  p256dh      String   @db.VarChar(200)
  auth        String   @db.VarChar(100)
  userAgent   String?  @db.VarChar(255)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("push_subscriptions")
}

// ─── Missing Models (migrated from legacy) ────────────────────────────────────

model NsmDailyRecord {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date         DateTime @unique @db.Date
  filledOrders Int
  target       Int      @default(500)
  percentage   Float
  alertSent    Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@map("nsm_daily_records")
}

model DataExportJob {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String          @db.Uuid
  status      ExportJobStatus @default(PENDING)
  format      String          @default("json+csv") @db.VarChar(20)
  filePath    String?         @db.VarChar(500)
  downloadUrl String?         @db.VarChar(500)
  expiresAt   DateTime?
  error       String?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("data_export_jobs")
}

model BlockedWord {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  word      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now())

  @@map("blocked_words")
}

model GlobalForumPost {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  content   String   @db.VarChar(280)
  ticker    String?  @db.VarChar(10)
  isFlagged Boolean  @default(false)
  flagCount Int      @default(0)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id])
  likes ForumLike[]

  @@index([userId])
  @@index([ticker])
  @@index([createdAt])
  @@map("global_forum_posts")
}

model ForumLike {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId    String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now())

  post GlobalForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("forum_likes")
}

model ModerationRule {
  id          Int      @id
  name        String   @db.VarChar(100)
  description String
  enabled     Boolean  @default(false)
  config      Json?
  updatedAt   DateTime @default(now()) @updatedAt

  @@map("moderation_rules")
}

model AdSponsor {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @db.VarChar(100)
  logo         String?
  banners      Json     @default("{}")
  activeLigaId String?  @db.VarChar(50)
  startsAt     DateTime
  endsAt       DateTime
  active       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("ad_sponsors")
}

model WebhookAuditLog {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gateway        PaymentGateway
  eventType      String?             @db.VarChar(60)
  transactionId  String?             @db.VarChar(255)
  subscriptionId String?             @db.Uuid
  status         WebhookAuditStatus
  hmacValid      Boolean
  ipAddress      String?             @db.VarChar(45)
  errorMessage   String?
  processedAt    DateTime            @default(now())

  @@index([gateway, status])
  @@index([processedAt])
  @@index([transactionId])
  @@map("webhook_audit_logs")
}

model DunningAttempt {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionId String         @db.Uuid
  attemptNumber  Int
  gateway        PaymentGateway
  status         PaymentStatus  @default(PENDING)
  scheduledAt    DateTime
  processedAt    DateTime?
  errorMessage   String?
  createdAt      DateTime       @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@unique([subscriptionId, attemptNumber])
  @@index([scheduledAt, status])
  @@map("dunning_attempts")
}

model Dividend {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @db.Uuid
  ticker         String    @db.VarChar(10)
  clubName       String    @db.VarChar(100)
  type           String    @db.VarChar(20)
  amount         Decimal   @db.Decimal(18, 8)
  yieldPercent   Float
  status         String    @default("PENDING") @db.VarChar(20)
  processedMonth String?   @db.VarChar(7)
  scheduledFor   DateTime?
  triggerEvent   String?   @db.VarChar(40)
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([ticker])
  @@index([processedMonth])
  @@index([status, scheduledFor])
  @@index([status, createdAt])
  @@map("dividends")
}

model IncidentLog {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type            String    @db.VarChar(60)
  description     String    @db.Text
  affectedUsers   Int
  dataTypes       String[]
  detectedAt      DateTime
  containedAt     DateTime?
  estimatedImpact String    @db.VarChar(255)
  report          String    @db.Text
  notifiedAt      DateTime  @default(now())
  emailSent       Boolean   @default(true)
  createdAt       DateTime  @default(now())

  @@map("incident_logs")
}

model LeagueScoreEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leagueId  String   @db.Uuid
  userId    String   @db.Uuid
  eventType String   @db.VarChar(60)
  points    Int      @default(0)
  metadata  Json?
  period    String   @db.VarChar(10)
  createdAt DateTime @default(now())

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leagueId, userId, eventType, period])
  @@index([leagueId, userId])
  @@index([leagueId, period])
  @@map("league_score_events")
}

model NewsSourceWhitelist {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  domain    String   @unique @db.VarChar(255)
  addedBy   String   @db.VarChar(100)
  createdAt DateTime @default(now())

  @@map("news_source_whitelist")
}
