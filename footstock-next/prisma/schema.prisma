// ─── module-16: Dividendos ────────────────────────────────────────────────────

model Dividend {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  ticker         String
  clubName       String    @map("club_name")
  // DividendType: ESPORTIVO | FINANCEIRO (legado) | SPORTING_RESULT | FINANCIAL_PERIODIC | YIELD_DIFFERENTIAL
  type           String
  amount         Decimal   @db.Decimal(18, 8)
  yieldPercent   Float     @map("yield_percent")
  // DividendStatus: CREDITED | PENDING | EXPIRADO | BLOCKED_PLAN
  status         String    @default("PENDING")
  processedMonth String?   @map("processed_month") // "YYYY-MM" — idempotência do job mensal
  scheduledFor   DateTime? @map("scheduled_for") // prazo PENDING (createdAt + 7 dias)
  triggerEvent   String?   @map("trigger_event") // VITORIA | TITULO | CAMPEONATO (apenas SPORTING_RESULT)
  snapshotDate   DateTime? @map("snapshot_date") // data de corte de acionistas (quem detinha nessa data recebe)
  sharesSnapshot Decimal?  @map("shares_snapshot") @db.Decimal(18, 8) // qtd de ações na snapshotDate
  pricePerShare  Decimal?  @map("price_per_share") @db.Decimal(18, 8) // valor por ação distribuído
  createdAt      DateTime  @default(now()) @map("created_at")

  user                     User                       @relation(fields: [userId], references: [id])
  yieldDifferentialPending YieldDifferentialPending[]

  @@index([userId])
  @@index([ticker])
  @@index([processedMonth])
  @@index([status, scheduledFor]) // job de crédito
  @@index([status, createdAt]) // job de expiração
  @@index([userId, type]) // filtro por tipo na listagem
  @@map("dividends")
}

/// Accrual pendente de yield para usuários JOGADOR.
/// JOGADOR não recebe crédito direto; o yield acumula aqui e é realizado na venda da posição.
model YieldDifferentialPending {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  ticker                String
  /// Tipo fonte: SPORTING_RESULT | FINANCIAL_PERIODIC
  sourceType            String    @map("source_type")
  /// FK para `dividends.id` que gerou este pendente (para rastreabilidade)
  sourceDividendId      String?   @map("source_dividend_id")
  snapshotDate          DateTime  @map("snapshot_date")
  /// Qtd de ações na snapshotDate (para cálculo proporcional em venda parcial)
  sharesSnapshot        Decimal   @map("shares_snapshot") @db.Decimal(18, 8)
  /// Yield acumulado ainda não realizado
  pendingAmount         Decimal   @map("pending_amount") @db.Decimal(18, 8)
  /// PENDING | REALIZED | UPGRADED (migrado por upgrade de plano)
  status                String    @default("PENDING")
  realizedAt            DateTime? @map("realized_at")
  realizedTransactionId String?   @map("realized_transaction_id")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user           User      @relation(fields: [userId], references: [id])
  sourceDividend Dividend? @relation(fields: [sourceDividendId], references: [id])

  @@unique([userId, sourceDividendId]) // evita duplicação por evento
  @@index([userId, status])
  @@index([userId, ticker])
  @@map("yield_differential_pending")
}

