// RESOLVED: modelo criado para rastrear eventos de pontuação do Pilar 2 (Sofisticação Operacional)
// Registra AI_CONSULTED, LIMIT_ORDER_EXECUTED, OCO_EXECUTED, SHORT_PROFITABLE, etc.
model LeagueScoreEvent {
  id        String   @id @default(cuid())
  leagueId  String   @map("league_id")
  userId    String   @map("user_id")
  eventType String   @map("event_type") // AI_CONSULTED | LIMIT_ORDER_EXECUTED | OCO_EXECUTED | SHORT_PROFITABLE | SCHEDULED_ORDER_EXECUTED | GLOSSARY_5_CARDS | FORUM_POST_LIKED | GLOSSARY_3_CATEGORIES | PLAN_UPGRADED
  points    Int      @default(0)
  metadata  Json? // ticker, orderId, etc.
  period    String   @map("period") // "YYYY-MM-DD" — para deduplicação diária
  createdAt DateTime @default(now()) @map("created_at")

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // period semântica:
  //   eventos diários       → "YYYY-MM-DD"  (dedup por dia)
  //   SHORT_PROFITABLE_CLOSED → ISO timestamp  (sem dedup — N ocorrências/dia)
  //   únicos por liga       → "league"        (1× por liga)
  @@unique([leagueId, userId, eventType, period])
  @@index([leagueId, userId])
  @@index([leagueId, period])
  @@map("league_score_events")
}

