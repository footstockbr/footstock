// ─── Affiliate (Programa de Afiliados para Influenciadores) ──────────────────

enum AffiliateStatus {
  PENDING
  PROCESSING
  PAID
  VOIDED // Anulado por refund/chargeback — não será pago
}

model AffiliateCode {
  id                   String   @id @default(cuid())
  userId               String   @unique @map("user_id")
  code                 String   @unique @db.VarChar(50)
  // Valores válidos: USER | INFLUENCIADOR | TIME_PARCEIRO
  // USER = todo usuário padrão (commissionPercentage=0, sem acesso ao portal)
  // INFLUENCIADOR / TIME_PARCEIRO = afiliados elegíveis (ver affiliate-auth.ts)
  affiliateType        String   @default("USER") @map("affiliate_type") @db.VarChar(30)
  commissionPercentage Decimal  @default(0.00) @map("commission_percentage") @db.Decimal(5, 4)
  bankData             Json?    @map("bank_data")
  // bankData: { banco, agencia, conta, pixKey, cnpj } — criptografado em repouso
  active               Boolean  @default(true)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions AffiliateTransaction[]

  @@map("affiliate_codes")
}

model AffiliateTransaction {
  id                         String          @id @default(cuid())
  affiliateCodeId            String          @map("affiliate_code_id")
  referredUserId             String          @map("referred_user_id")
  subscriptionId             String?         @map("subscription_id")
  gatewayTransactionId       String?         @unique @map("gateway_transaction_id") @db.VarChar(255)
  // gatewayTransactionId: chave de idempotência — 1 comissão por evento de pagamento
  transactionType            String          @default("SIGNUP") @map("transaction_type") @db.VarChar(30)
  // transactionType: SIGNUP | SUBSCRIPTION_RENEWAL | CONVERSION
  amount                     Decimal         @default(0) @db.Decimal(14, 8)
  // amount em FS$ (tokens da plataforma)
  commissionPercentageAtTime Decimal?        @map("commission_percentage_at_time") @db.Decimal(5, 4)
  // snapshot da taxa no momento da transação — preserva histórico mesmo se admin editar %
  status                     AffiliateStatus @default(PENDING)
  paidAt                     DateTime?       @map("paid_at")
  createdAt                  DateTime        @default(now()) @map("created_at")

  affiliateCode AffiliateCode @relation(fields: [affiliateCodeId], references: [id], onDelete: Cascade)
  referredUser  User          @relation("AffiliateReferredUser", fields: [referredUserId], references: [id])

  @@map("affiliate_transactions")
}

