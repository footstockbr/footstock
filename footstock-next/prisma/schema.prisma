// Foot Stock — Prisma Schema
// Gerado por /back-end-build em 2026-03-28
// Referência: output/docs/foot-stock/project/LLD.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum PositionStatus {
  OPEN
  CLOSED
}

enum WebhookAuditStatus {
  ACCEPTED
  REJECTED
  DUPLICATE
}

enum ConsentPurpose {
  ESSENTIAL
  ANALYTICS
  MARKETING
  DATA_TERCEIROS
  AGE_VERIFICATION
}

enum ExportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}


enum InvestorProfile {
  INICIANTE
  INTERMEDIARIO
  AVANCADO
  FA_FUTEBOL
}

enum PlanType {
  JOGADOR
  CRAQUE
  LENDA
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  ADMINISTRADOR
  MONITOR
  EDITOR
  MODERADOR
  CLUB_PARTNER
}

enum OrderType {
  MARKET
  LIMIT
  OCO
  SHORT
  SCHEDULED
}

enum OrderSide {
  BUY
  SELL
}

enum OrderStatus {
  PENDING
  OPEN
  EXECUTED
  FILLED
  CANCELLED
  EXPIRED
  PARTIAL
}

enum PositionSide {
  LONG
  SHORT
}



enum TransactionType {
  BUY
  SELL
  FEE
  DIVIDEND
  MARGIN_CALL
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING_PAYMENT
  CANCELLATION_LOCK
}

enum SubscriptionGateway {
  MERCADO_PAGO
  PAGSEGURO
  PAYPAL
}

enum SubscriptionPeriod {
  MONTHLY
  ANNUAL
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
  CHARGEBACK
}

enum ImpactCategory {
  RESULTADO_ESPORTIVO
  CONTRATACAO
  FINANCEIRO
  LESAO
  SUSPENSAO
  INSTITUCIONAL
}

enum LeagueType {
  PUBLICA
  AMIGOS
  PRO
}



enum PostStatus {
  ACTIVE
  REMOVED
  FLAGGED
}




enum Division {
  SERIE_A
  SERIE_B
}

enum Sentiment {
  BULLISH
  BEARISH
  NEUTRAL
}

enum NotificationType {
  ORDER_EXECUTED
  ORDER_CANCELLED
  MARGIN_CALL_ALERT
  CIRCUIT_BREAKER
  NEWS_FAVORITE_CLUB
  PAYMENT_CONFIRMED
  PAYMENT_FAILED
  PLAN_CANCEL_ALERT
  DIVIDEND_CREDITED
  BONUS_CREDITED
  LEAGUE_RESULT
  ADMIN_BROADCAST
  CANCELLATION_LOCK_ACTIVE
  CANCELLATION_LOCK_LIQUIDATED
}

enum FinancialType {
  TRADE
  BONUS
  DEPOSIT
  WITHDRAWAL
  SHORT_INTEREST
  MARGIN_BLOCKED
  SHORT_CLOSE
  LEVERAGE_INTEREST
}

enum SessionType {
  PRE_MARKET
  REGULAR
  AFTER_MARKET
  CLOSED
}

enum AffiliateStatus {
  PENDING
  PAID
  CANCELLED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                      String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                   String          @unique @db.VarChar(255)
  cpfHash                 String          @unique @db.Char(64) @map("cpf_hash")
  name                    String          @db.VarChar(120)
  phone                   String?         @db.VarChar(20)
  birthDate               DateTime?        @db.Date @map("birth_date")
  favoriteClub            String?          @db.VarChar(10) @map("favorite_club")
  favoriteClubDisplayName String?         @db.VarChar(100) @map("favorite_club_display_name")
  userType                String           @default("NORMAL") @map("user_type")
  referredByCode          String?         @db.VarChar(20) @map("referred_by_code")
  investorProfile         InvestorProfile? @map("investor_profile")
  planType                PlanType        @default(JOGADOR) @map("plan_type")
  fsBalance               Decimal         @default(2000.00) @db.Decimal(12, 2) @map("fs_balance")
  marginBlocked           Decimal         @default(0.00) @db.Decimal(12, 2) @map("margin_blocked")
  tourCompleted           Boolean         @default(false) @map("tour_completed")
  ageVerificationPending  Boolean         @default(false) @map("age_verification_pending")
  adminRole               AdminRole? @map("admin_role")
  status                  UserStatus      @default(ACTIVE)
  bio                     String?         @db.VarChar(300)
  suspendedAt             DateTime? @map("suspended_at")
  suspensionReason        String?         @db.VarChar(500) @map("suspension_reason")
  version                 Int             @default(0)
  createdAt               DateTime        @default(now()) @map("created_at")
  updatedAt               DateTime        @updatedAt @map("updated_at")

  orders               Order[]
  positions            Position[]
  transactions         Transaction[]
  notifications        Notification[]
  forumPosts           ForumPost[]
  globalForumPosts     GlobalForumPost[]
  forumLikes           ForumLike[]
  consents             Consent[]
  dataAccessLogs       DataAccessLog[]  @relation("UserDataAccessLogs")
  accessedDataLogs     DataAccessLog[]  @relation("AdminDataAccessLogs")
  subscription         Subscription?
  affiliateCodes       AffiliateCode[]
  affiliateTransactions AffiliateTransaction[] @relation("ReferredUser")
  pushSubscriptions    PushSubscription[]
  adminActions         AdminMarketAction[]
  leagueMembers        LeagueMember[]
  glossaryInteractions GlossaryInteraction[]
  dataExportJobs       DataExportJob[]
  dividends            Dividend[]
  leagueScoreEvents    LeagueScoreEvent[]

  @@index([email])
  @@index([cpfHash])
  @@index([planType])
  @@index([userType])
  @@index([referredByCode])
  @@map("users")
}

model Asset {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticker         String         @unique @db.VarChar(10)
  name           String         @db.VarChar(100)
  realName       String         @db.VarChar(80) @map("real_name")
  displayName    String         @db.VarChar(100) @map("display_name")
  division       Division
  currentPrice   Decimal        @db.Decimal(10, 4) @map("current_price")
  fairValue      Decimal        @db.Decimal(10, 4) @map("fair_value")
  openPrice      Decimal        @default(0) @db.Decimal(10, 4) @map("open_price")
  closePrice     Decimal        @default(0) @db.Decimal(10, 4) @map("close_price")
  cluster        String         @default("A_TOP") @db.VarChar(20)
  volume         BigInt         @default(0)
  currentSupply  BigInt @map("current_supply")
  totalShares    BigInt @map("total_shares")
  isActive       Boolean        @default(true) @map("is_active")
  isHalted       Boolean        @default(false) @map("is_halted")
  haltReason     String?        @db.VarChar(100) @map("halt_reason")
  colorPrimary   String         @default("#000000") @db.VarChar(20) @map("color_primary")
  colorSecondary String         @default("#FFFFFF") @db.VarChar(20) @map("color_secondary")
  colors         Json
  financials     Json
  sentiment      String         @default("NEUTRAL")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  orders       Order[]
  positions    Position[]
  priceHistory PriceHistory[]
  news         News[]

  @@index([ticker])
  @@index([division])
  @@map("assets")
}

model Order {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String      @db.Uuid @map("user_id")
  ticker          String      @db.VarChar(10)
  type            OrderType
  side            OrderSide
  quantity        Decimal     @db.Decimal(14, 4)
  price           Decimal?    @db.Decimal(10, 4)
  executedPrice   Decimal?    @db.Decimal(10, 4) @map("executed_price")
  status          OrderStatus @default(PENDING)
  stopLossPrice   Decimal?    @db.Decimal(10, 4) @map("stop_loss_price")
  takeProfitPrice Decimal?    @db.Decimal(10, 4) @map("take_profit_price")
  scheduledAt     DateTime? @map("scheduled_at")
  feeAmount       Decimal?    @db.Decimal(8, 2) @map("fee_amount")
  leverageMultiplier Int      @default(1) @map("leverage_multiplier")
  executedAt      DateTime? @map("executed_at")
  expiresAt       DateTime? @map("expires_at")
  groupId         String?     @db.VarChar(50) @map("group_id")
  version         Int         @default(0)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id])
  asset        Asset         @relation(fields: [ticker], references: [ticker])
  transactions Transaction[]

  @@index([userId, status])
  @@index([ticker, status])
  @@index([groupId])
  @@map("orders")
}

model Position {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String       @db.Uuid @map("user_id")
  ticker              String       @db.VarChar(10)
  quantity            Decimal      @db.Decimal(14, 4)
  avgPrice            Decimal      @db.Decimal(10, 4) @map("avg_price")
  totalInvested       Decimal      @default(0) @db.Decimal(12, 2) @map("total_invested")
  side                PositionSide
  status              PositionStatus @default(OPEN)
  marginBlocked       Decimal      @default(0) @db.Decimal(12, 2) @map("margin_blocked")
  leverageMultiplier  Decimal      @default(1.0) @db.Decimal(3, 1) @map("leverage_multiplier")
  leverageAmount      Decimal      @default(0.0) @db.Decimal(12, 2) @map("leverage_amount")
  dailyInterestRate   Decimal      @default(0.0) @db.Decimal(6, 4) @map("daily_interest_rate")
  interestAccrued     Decimal      @default(0.0) @db.Decimal(10, 2) @map("interest_accrued")
  openedAt            DateTime? @map("opened_at")
  version             Int          @default(0)
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id])
  asset Asset @relation(fields: [ticker], references: [ticker])

  @@index([userId])
  @@index([userId, status])
  @@index([ticker])
  @@map("positions")
}

model Transaction {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String          @db.Uuid @map("user_id")
  orderId       String?         @db.Uuid @map("order_id")
  ticker        String          @db.VarChar(10)
  type          TransactionType
  amount        Decimal         @db.Decimal(14, 4)
  fsAmount      Decimal         @db.Decimal(12, 2) @map("fs_amount")
  balanceBefore Decimal         @db.Decimal(12, 2) @map("balance_before")
  balanceAfter  Decimal         @db.Decimal(12, 2) @map("balance_after")
  createdAt     DateTime        @default(now()) @map("created_at")

  user  User   @relation(fields: [userId], references: [id])
  order Order? @relation(fields: [orderId], references: [id])

  @@index([userId])
  @@index([ticker])
  @@map("transactions")
}

model PriceHistory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticker    String   @db.VarChar(10)
  open      Decimal  @db.Decimal(10, 4)
  high      Decimal  @db.Decimal(10, 4)
  low       Decimal  @db.Decimal(10, 4)
  close     Decimal  @db.Decimal(10, 4)
  volume    Decimal  @db.Decimal(18, 4)
  period    String   @db.VarChar(4)
  timestamp DateTime

  asset Asset @relation(fields: [ticker], references: [ticker])

  @@index([ticker, period, timestamp(sort: Desc)])
  @@map("price_history")
}

model Subscription {
  id                        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                    String             @unique @db.Uuid @map("user_id")
  planType                  PlanType @map("plan_type")
  previousPlanType          PlanType? @map("previous_plan_type")
  gateway                   SubscriptionGateway
  period                    SubscriptionPeriod
  amount                    Int                @default(0)
  status                    SubscriptionStatus
  startsAt                  DateTime @map("starts_at")
  expiresAt                 DateTime? @map("expires_at")
  trialEndsAt               DateTime? @map("trial_ends_at")
  cancelledAt               DateTime? @map("cancelled_at")
  cancellationLockExpiresAt DateTime? @map("cancellation_lock_expires_at")
  bonusScheduledAt          DateTime? @map("bonus_scheduled_at")
  bonusCreditedAt           DateTime? @map("bonus_credited_at")
  renewalReminderSentAt     DateTime? @map("renewal_reminder_sent_at")
  refundRequested           Boolean            @default(false) @map("refund_requested")
  createdAt                 DateTime           @default(now()) @map("created_at")
  updatedAt                 DateTime           @updatedAt @map("updated_at")

  user                  User                   @relation(fields: [userId], references: [id])
  payments              Payment[]
  affiliateTransactions AffiliateTransaction[]
  dunningAttempts       DunningAttempt[]

  @@index([expiresAt, status])
  @@index([cancellationLockExpiresAt, status])
  @@index([renewalReminderSentAt, status])
  @@map("subscriptions")
}

model Payment {
  id                   String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionId       String         @db.Uuid @map("subscription_id")
  gateway              SubscriptionGateway
  gatewayTransactionId String         @unique @db.VarChar(255) @map("gateway_transaction_id")
  amount               Decimal        @db.Decimal(10, 2)
  currency             String         @default("BRL") @db.VarChar(3)
  status               PaymentStatus
  gatewayMeta          Json? @map("gateway_meta")
  processedAt          DateTime? @map("processed_at")
  createdAt            DateTime       @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@map("payments")
}

model News {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title          String         @db.VarChar(255)
  content        String?        @db.Text
  source         String         @db.VarChar(100)
  url            String         @db.VarChar(500)
  ticker         String         @db.VarChar(10)
  assetIds       String[]
  sentiment      Decimal        @db.Decimal(4, 3)
  impactCategory ImpactCategory @map("impact_category")
  isPublished    Boolean        @default(true) @map("is_published")
  status         String         @default("published") @db.VarChar(20)
  publishedAt    DateTime @map("published_at")
  injectedAt     DateTime       @default(now()) @map("injected_at")
  createdAt      DateTime       @default(now()) @map("created_at")

  asset Asset @relation(fields: [ticker], references: [ticker])

  @@index([ticker])
  @@index([status])
  @@index([isPublished])
  @@index([injectedAt(sort: Desc)])
  @@map("news")
}

model League {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String         @db.VarChar(60)
  slug      String         @unique @db.VarChar(80)
  type      LeagueType
  division  String           @default("BRONZE")
  duration  String         @db.VarChar(12) // '1S' | '1M' | 'TEMPORADA'
  sponsorId String?        @db.Uuid @map("sponsor_id")
  createdBy String?        @db.Uuid @map("created_by")
  startsAt  DateTime @map("starts_at")
  endsAt    DateTime? @map("ends_at")
  status    String           @default("ACTIVE")
  createdAt DateTime       @default(now()) @map("created_at")

  sponsor     Sponsor?           @relation(fields: [sponsorId], references: [id])
  members     LeagueMember[]
  scoreEvents LeagueScoreEvent[]

  @@index([type, status])
  @@map("leagues")
}

model LeagueMember {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leagueId       String    @db.Uuid @map("league_id")
  userId         String    @db.Uuid @map("user_id")
  score          Decimal   @default(0) @db.Decimal(12, 4) // = finalScore
  rank           Int       @default(0)
  scoreBreakdown Json?     // ScoreBreakdown completo em JSON @map("score_breakdown")
  joinedAt       DateTime  @default(now()) @map("joined_at")
  lastScoreAt    DateTime? @map("last_score_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leagueId, userId])
  @@index([leagueId, score(sort: Desc)])
  @@map("league_members")
}

model GlossaryInteraction {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  termSlug  String   @db.VarChar(100) @map("term_slug")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("glossary_interactions")
}

model ForumPost {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String     @db.Uuid @map("user_id")
  content   String     @db.VarChar(280)
  ticker    String?    @db.VarChar(10)
  status    PostStatus @default(ACTIVE)
  likes     Int        @default(0)
  flagged   Boolean    @default(false)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([ticker])
  @@index([status])
  @@map("forum_posts")
}

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  type      String   @db.VarChar(40)
  title     String   @db.VarChar(120)
  body      String   @db.VarChar(500)
  read      Boolean  @default(false)
  isRead    Boolean  @default(false) @map("is_read")
  data      Json?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([userId, isRead])
  @@map("notifications")
}

model Consent {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String         @db.Uuid @map("user_id")
  purpose   ConsentPurpose
  granted   Boolean        @default(true)
  grantedAt DateTime       @default(now()) @map("granted_at")
  ipAddress String?        @db.VarChar(45) @map("ip_address")
  userAgent String?        @db.VarChar(255) @map("user_agent")
  revoked   Boolean        @default(false)
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, purpose])
  @@index([userId])
  @@map("consents")
}

model DataAccessLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid @map("user_id")
  accessedBy  String   @db.Uuid @map("accessed_by")
  action      String   @db.VarChar(60)
  dataType    String?  @db.VarChar(60) @map("data_type")
  endpoint    String?  @db.VarChar(255)
  details     Json?
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now()) @map("created_at")

  user     User @relation("UserDataAccessLogs", fields: [userId], references: [id])
  accessor User @relation("AdminDataAccessLogs", fields: [accessedBy], references: [id])

  @@index([userId])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([timestamp(sort: Desc)])
  @@map("data_access_logs")
}

model Sponsor {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(120)
  banners   Json?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  leagues League[]

  @@map("sponsors")
}

model AdminMarketAction {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminId      String   @db.Uuid @map("admin_id")
  action       String   @db.VarChar(40)
  targetTicker String?  @db.VarChar(10) @map("target_ticker")
  details      Json?
  timestamp    DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([timestamp(sort: Desc)])
  @@map("admin_market_actions")
}

model AffiliateCode {
  id                   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String        @db.Uuid @map("user_id")
  code                 String        @unique @db.VarChar(20)
  affiliateType        String        @default("INFLUENCER") @map("affiliate_type")
  commissionPercentage Decimal       @db.Decimal(5, 2) @map("commission_percentage")
  bankData             Json? @map("bank_data")
  active               Boolean       @default(true)
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  user         User                   @relation(fields: [userId], references: [id])
  transactions AffiliateTransaction[]

  @@map("affiliate_codes")
}

model AffiliateTransaction {
  id                String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  affiliateCodeId   String                     @db.Uuid @map("affiliate_code_id")
  referredUserId    String                     @db.Uuid @map("referred_user_id")
  subscriptionId    String                     @db.Uuid @map("subscription_id")
  transactionType   String                   @default("SIGNUP") @map("transaction_type")
  amount            Decimal                    @db.Decimal(10, 2)
  status            AffiliateStatus @default(PENDING)
  paidAt            DateTime? @map("paid_at")
  createdAt         DateTime                   @default(now()) @map("created_at")

  affiliateCode AffiliateCode @relation(fields: [affiliateCodeId], references: [id])
  referredUser  User          @relation("ReferredUser", fields: [referredUserId], references: [id])
  subscription  Subscription  @relation(fields: [subscriptionId], references: [id])

  @@map("affiliate_transactions")
}

model PushSubscription {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid @map("user_id")
  endpoint    String   @unique @db.VarChar(500)
  p256dh      String   @db.VarChar(200)
  auth        String   @db.VarChar(100)
  userAgent   String?  @db.VarChar(255) @map("user_agent")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("push_subscriptions")
}

// ─── Missing Models (migrated from legacy) ────────────────────────────────────

model NsmDailyRecord {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date         DateTime @unique @db.Date
  filledOrders Int @map("filled_orders")
  target       Int      @default(500)
  percentage   Float
  alertSent    Boolean  @default(false) @map("alert_sent")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("nsm_daily_records")
}

model DataExportJob {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String          @db.Uuid @map("user_id")
  status      ExportJobStatus @default(PENDING)
  format      String          @default("json+csv") @db.VarChar(20)
  filePath    String?         @db.VarChar(500) @map("file_path")
  downloadUrl String?         @db.VarChar(500) @map("download_url")
  expiresAt   DateTime? @map("expires_at")
  error       String?
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("data_export_jobs")
}

model BlockedWord {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  word      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("blocked_words")
}

model GlobalForumPost {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  content   String   @db.VarChar(280)
  ticker    String?  @db.VarChar(10)
  isFlagged Boolean  @default(false) @map("is_flagged")
  flagCount Int      @default(0) @map("flag_count")
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User        @relation(fields: [userId], references: [id])
  likes ForumLike[]

  @@index([userId])
  @@index([ticker])
  @@index([createdAt])
  @@map("global_forum_posts")
}

model ForumLike {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId    String   @db.Uuid @map("post_id")
  userId    String   @db.Uuid @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  post GlobalForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("forum_likes")
}

model ModerationRule {
  id          Int      @id
  name        String   @db.VarChar(100)
  description String
  enabled     Boolean  @default(false)
  config      Json?
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("moderation_rules")
}

model AdSponsor {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @db.VarChar(100)
  logo         String?
  banners      Json     @default("{}")
  activeLigaId String?  @db.VarChar(50) @map("active_liga_id")
  startsAt     DateTime @map("starts_at")
  endsAt       DateTime @map("ends_at")
  active       Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("ad_sponsors")
}

model WebhookAuditLog {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gateway        SubscriptionGateway
  eventType      String?             @db.VarChar(60) @map("event_type")
  transactionId  String?             @db.VarChar(255) @map("transaction_id")
  subscriptionId String?             @db.Uuid @map("subscription_id")
  status         WebhookAuditStatus
  hmacValid      Boolean @map("hmac_valid")
  ipAddress      String?             @db.VarChar(45) @map("ip_address")
  errorMessage   String? @map("error_message")
  processedAt    DateTime            @default(now()) @map("processed_at")

  @@index([gateway, status])
  @@index([processedAt])
  @@index([transactionId])
  @@map("webhook_audit_logs")
}

model DunningAttempt {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionId String         @db.Uuid @map("subscription_id")
  attemptNumber  Int @map("attempt_number")
  gateway        SubscriptionGateway
  status         PaymentStatus  @default(PENDING)
  scheduledAt    DateTime @map("scheduled_at")
  processedAt    DateTime? @map("processed_at")
  errorMessage   String? @map("error_message")
  createdAt      DateTime       @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@unique([subscriptionId, attemptNumber])
  @@index([scheduledAt, status])
  @@map("dunning_attempts")
}

model Dividend {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @db.Uuid @map("user_id")
  ticker         String    @db.VarChar(10)
  clubName       String    @db.VarChar(100) @map("club_name")
  type           String    @db.VarChar(20)
  amount         Decimal   @db.Decimal(18, 8)
  yieldPercent   Float @map("yield_percent")
  status         String    @default("PENDING") @db.VarChar(20)
  processedMonth String?   @db.VarChar(7) @map("processed_month")
  scheduledFor   DateTime? @map("scheduled_for")
  triggerEvent   String?   @db.VarChar(40) @map("trigger_event")
  createdAt      DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([ticker])
  @@index([processedMonth])
  @@index([status, scheduledFor])
  @@index([status, createdAt])
  @@map("dividends")
}

model IncidentLog {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type            String    @db.VarChar(60)
  description     String    @db.Text
  affectedUsers   Int @map("affected_users")
  dataTypes       String[]
  detectedAt      DateTime @map("detected_at")
  containedAt     DateTime? @map("contained_at")
  estimatedImpact String    @db.VarChar(255) @map("estimated_impact")
  report          String    @db.Text
  notifiedAt      DateTime  @default(now()) @map("notified_at")
  emailSent       Boolean   @default(true) @map("email_sent")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("incident_logs")
}

model LeagueScoreEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leagueId  String   @db.Uuid @map("league_id")
  userId    String   @db.Uuid @map("user_id")
  eventType String   @db.VarChar(60) @map("event_type")
  points    Int      @default(0)
  metadata  Json?
  period    String   @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at")

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leagueId, userId, eventType, period])
  @@index([leagueId, userId])
  @@index([leagueId, period])
  @@map("league_score_events")
}

model NewsSourceWhitelist {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  domain    String   @unique @db.VarChar(255)
  addedBy   String   @db.VarChar(100) @map("added_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("news_source_whitelist")
}
