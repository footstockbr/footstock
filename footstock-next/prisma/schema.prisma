  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leagueId, userId, date])
  @@index([leagueId, date])
  @@index([userId])
  @@map("league_daily_ranks")
}

