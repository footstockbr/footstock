DATABASE_URL=postgresql://user:password@localhost:5432/footstock
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ANTHROPIC_API_KEY=your-anthropic-api-key
NEXT_PUBLIC_SOCKET_URL=https://your-railway-app.railway.app

# Redis (conexão direta — Redis Cloud, Railway Redis, ou local)
REDIS_URL=redis://default:[password]@[host]:[port]

# Segurança — CPF Hash (module-4)
HMAC_CPF_SECRET=         # RECOMENDADO: Secret para HMAC-SHA256 do CPF (min 32 chars) — NUNCA compartilhar
CPF_HASH_SALT=           # LEGADO: Fallback SHA-256+salt (usado se HMAC_CPF_SECRET não estiver definido)

# FlagCheck — Verificação de maioridade ECA Digital (module-4)
FLAGCHECK_API_URL=        # URL da API FlagCheck para verificação de maioridade
FLAGCHECK_API_KEY=        # Chave da API FlagCheck

# module-20-ligas
CRON_SECRET=               # Bearer secret para o endpoint /api/cron/scoring (min 32 chars)
INVITE_TOKEN_SECRET=       # Segredo JWT para tokens de convite de liga (expiração 7d)
NEXT_PUBLIC_ENABLE_EMBLEM_UPLOAD=false  # Feature flag para upload de emblema de liga (Could)
