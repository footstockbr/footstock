DATABASE_URL=postgresql://user:password@localhost:5432/footstock
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ANTHROPIC_API_KEY=your-anthropic-api-key
NEXT_PUBLIC_SOCKET_URL=https://your-railway-app.railway.app

# Redis (conexão direta — Redis Cloud, Railway Redis, ou local)
REDIS_URL=redis://default:[password]@[host]:[port]

# Segurança — CPF Hash (module-4)
HMAC_CPF_SECRET=         # RECOMENDADO: Secret para HMAC-SHA256 do CPF (min 32 chars) — NUNCA compartilhar
CPF_HASH_SALT=           # LEGADO: Fallback SHA-256+salt (usado se HMAC_CPF_SECRET não estiver definido)

# module-19-notificacoes — Web Push VAPID
# Gerar: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=   # Chave pública VAPID (exposta no bundle — seguro, é publica por definição)
VAPID_PRIVATE_KEY=              # Chave privada VAPID — NUNCA commitar valor real

# module-20-ligas
CRON_SECRET=               # Bearer secret para o endpoint /api/cron/scoring (min 32 chars)
INVITE_TOKEN_SECRET=       # Segredo JWT para tokens de convite de liga (expiração 7d)
NEXT_PUBLIC_ENABLE_EMBLEM_UPLOAD=false  # Feature flag para upload de emblema de liga (Could)

# T-029 — Analytics Mixpanel
NEXT_PUBLIC_MIXPANEL_TOKEN=      # Token do projeto Mixpanel (publico, exposto no cliente)
NEXT_PUBLIC_APP_VERSION=1.0.0    # Versao do app para super property

# T-023 — FlagCheck: Verificação de maioridade via CPF
FLAGCHECK_API_URL=             # URL da API FlagCheck (ex: https://api.flagcheck.com.br/v1)
FLAGCHECK_API_KEY=             # Chave de autenticação da API FlagCheck

# Railway Mitigation (2026-05-06) — tick interval e URLs de streaming/API
NEXT_PUBLIC_TICK_INTERVAL_MS=10000
NEXT_PUBLIC_STREAM_URL=https://stream.footstock.com.br
NEXT_PUBLIC_API_URL=https://api.footstock.com.br
