# ============================================================================
# FootStock Motor — Variáveis de Ambiente
# Copie para .env e preencha com os valores reais.
# NUNCA comite o arquivo .env com valores reais.
# ============================================================================

# ─── Redis (Upstash ou Railway Redis) ────────────────────────────────────────
# SECRETO: nunca commitar valor real
REDIS_URL=redis://default:PASS@redis.railway.internal:6379
REDIS_TLS=false

# ─── Motor ───────────────────────────────────────────────────────────────────
MOTOR_TICK_INTERVAL_MS=10000
MOTOR_LEADER_TTL_S=30
MOTOR_LEADER_HEARTBEAT_S=10
MOTOR_CIRCUIT_BREAKER_THRESHOLD=0.08
MOTOR_CIRCUIT_BREAKER_HALT_DURATION_S=300

# T3.3 (loop 06-17-motor-footstock-correcoes-variacoes): escala temporal (dt) do
# tick consumida por L1_OU/L2_Anchor/L3_GARCH (ruido ~ sigma*sqrt(dt)). EXPLICITO
# e auditavel: deixar VAZIO usa o DEFAULT-SAFE legacy (1/390 do tick de 2s ajustado
# ao tick de 10s = 5/390 ~= 0.0128205), que replica a calibracao legacy sem inflar
# o ruido da abertura (Bug 1). Definir um numero finito > 0 sobrescreve explicitamente
# (valor invalido => fail-fast, proibido default acidental). NAO definir em prod salvo
# decisao do quant.
# MOTOR_TICK_DT_SECONDS=0.0128205
#
# Alternativa atras de flag: recalibracao FORMAL para o passo unitario (dt=1.0). Exige
# re-tunar sigma/cap por camada antes de ligar em prod. MOTOR_TICK_DT_SECONDS tem
# precedencia sobre esta flag.
# MOTOR_TICK_DT_FORMAL_RECALIBRATION=false

# T1.4 (loop 06-17-motor-footstock-correcoes-variacoes): semantica de execucao de
# ordens reais. 'pre-agent' (DEFAULT-SAFE) casa ordens reais no preco PRE-agente
# (somente a dinamica do motor L1-L7, sem o overlay sintetico dos agentes). 'post-agent'
# casa no preco publicado (com o impacto do agente). A ratificacao pre vs pos e decisao
# de operador tecnico + produto/mercado; trocar de lado e so mudar esta flag.
# Qualquer valor diferente de 'post-agent' resolve para 'pre-agent'.
MOTOR_REAL_ORDER_MATCH_PRICE=pre-agent

# ─── Database (mesma instância do Next.js) ────────────────────────────────────
# SECRETO: nunca commitar valor real
DATABASE_URL=postgresql://USER:PASS@postgres.railway.internal:5432/railway

# ─── Admin ────────────────────────────────────────────────────────────────────
# SECRETO: nunca commitar valor real
MOTOR_ADMIN_SECRET=changeme

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development

# ─── Cron Proxy (Wave 1/2/3 — Option C: motor-as-orchestrator HTTP) ──────────
# O motor (leader-elected) faz HTTP autenticado para as routes /api/cron/* do
# servico Next.js (Railway service "web") em vez de duplicar logica.
# Decisao: pending-actions/foot-stock.md > FS-SCHED-W1-2026-05-15 (Opcao C).
# Obrigatorias quando MOTOR_SCHEDULER_ENABLED=true.
# Producao: https://footstock.com.br (publico, edge Railway).
# Alternativa interna (mais rapida, exige porta correta): http://web.railway.internal:PORT
FOOTSTOCK_NEXT_BASE_URL=https://footstock.com.br
# SECRETO: mesmo valor configurado no servico web (Next.js).
CRON_SECRET=changeme

# ─── Railway ─────────────────────────────────────────────────────────────────
# Automaticamente injetado pelo Railway em produção
# RAILWAY_REPLICA_ID=
# MOTOR_PORT=3001
