# ============================================================================
# FootStock Motor — Variáveis de Ambiente
# Copie para .env e preencha com os valores reais.
# NUNCA comite o arquivo .env com valores reais.
# ============================================================================

# ─── Redis (Upstash ou Railway Redis) ────────────────────────────────────────
# SECRETO: nunca commitar valor real
REDIS_URL=redis://default:PASS@redis.railway.internal:6379
REDIS_TLS=false

# ─── Motor ───────────────────────────────────────────────────────────────────
MOTOR_TICK_INTERVAL_MS=10000
MOTOR_LEADER_TTL_S=30
MOTOR_LEADER_HEARTBEAT_S=10
MOTOR_CIRCUIT_BREAKER_THRESHOLD=0.08
MOTOR_CIRCUIT_BREAKER_HALT_DURATION_S=300

# ─── Database (mesma instância do Next.js) ────────────────────────────────────
# SECRETO: nunca commitar valor real
DATABASE_URL=postgresql://USER:PASS@postgres.railway.internal:5432/railway

# ─── Admin ────────────────────────────────────────────────────────────────────
# SECRETO: nunca commitar valor real
MOTOR_ADMIN_SECRET=changeme

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development

# ─── Cron Proxy (Wave 1/2/3 — Option C: motor-as-orchestrator HTTP) ──────────
# O motor (leader-elected) faz HTTP autenticado para as routes /api/cron/* do
# servico Next.js (Railway service "web") em vez de duplicar logica.
# Decisao: pending-actions/foot-stock.md > FS-SCHED-W1-2026-05-15 (Opcao C).
# Obrigatorias quando MOTOR_SCHEDULER_ENABLED=true.
# Producao: https://footstock.com.br (publico, edge Railway).
# Alternativa interna (mais rapida, exige porta correta): http://web.railway.internal:PORT
FOOTSTOCK_NEXT_BASE_URL=https://footstock.com.br
# SECRETO: mesmo valor configurado no servico web (Next.js).
CRON_SECRET=changeme

# ─── Railway ─────────────────────────────────────────────────────────────────
# Automaticamente injetado pelo Railway em produção
# RAILWAY_REPLICA_ID=
# MOTOR_PORT=3001
